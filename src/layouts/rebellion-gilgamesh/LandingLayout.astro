---
// Rebellion Gilgamesh Landing Layout
// Used for the main game landing page with hero image
import RGBaseHead from '../../components/rebellion-gilgamesh/RGBaseHead.astro';
import RGBreadcrumb from '../../components/rebellion-gilgamesh/RGBreadcrumb.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import GameNavigationHeader from '../../components/GameNavigationHeader.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import CustomScrollbar from '../../components/CustomScrollbar.astro';
import DecorativeLines from '../../components/DecorativeLines.astro';
import { Image } from 'astro:assets';
import Analytics from '../../components/Analytics.astro';

import '../../styles/games/rebellion-gilgamesh/rg-colors.css';
import '../../styles/global.css';
import '../../styles/typography.css';
import '../../styles/games/rebellion-gilgamesh/rg-layout.css';
import '../../styles/games/rebellion-gilgamesh/rebellion-gilgamesh-landing.css';

export interface Props {
  title: string;
  description?: string;
  gameTitle?: string;
  heroImage?: any;
}

const { title, description, gameTitle, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <RGBaseHead title={title} description={description} />
    <slot name="head" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <Analytics />
  </head>
  <body class="rg-body">
    <CustomScrollbar />
    <div class="bg-layer rg-bg-primary"></div>
    <div class="bg-layer rg-bg-accent-1"></div>
    <div class="bg-layer rg-bg-accent-2"></div>
    <div class="bg-layer rg-bg-accent-3"></div>

    <div class="rg-content">
      <Header />
      <GameNavigationHeader currentPath={Astro.url.pathname} gameKey="rebellion-gilgamesh" />
      <MobileMenu />

      <div class="rg-container">
        <main class="rg-main" id="main-content">
          {
            heroImage && gameTitle && (
              <section class="hero-section">
                <div class="hero-image-wrapper">
                  <div class="hero-image-container">
                    <Image src={heroImage} alt={gameTitle} class="hero-image" width={1200} height={400} loading="eager" decoding="async" />
                    <div class="hero-overlay" />
                  </div>
                </div>
                <h1 class="hero-title">{gameTitle}</h1>
                <DecorativeLines />
              </section>
            )
          }

          {
            !heroImage && gameTitle && (
              <section class="rg-title-only-section">
                <h1 class="rg-title-only-heading">{gameTitle}</h1>
                <DecorativeLines />
              </section>
            )
          }

          <RGBreadcrumb
            showBackButton={true}
            gameKey="rebellion-gilgamesh"
            autoGenerate={true}
          />

          <div class="content-area">
            <slot />
          </div>
        </main>
      </div>

      <Footer />
    </div>
  </body>
</html>
