---
import { MercenaryImage, HWRarityIcon, CrystalIcon } from '../../components/horizon-walker/index.astro';
import CharacterFullBodyImage from '../../components/horizon-walker/CharacterFullBodyImage.astro';

interface Trait {
  name: string;
  description: string;
  characteristics?: string;
  notes?: string;
}

export interface Props {
  mercenaryData: any;
}

const { mercenaryData } = Astro.props;

const formatStat = value => {
  if (value === null || value === undefined) return '0';
  if (typeof value === 'number') return value.toString();
  return value.toString() || '0';
};

function getMercenaryDescription(usage: any): string {
  if (!usage || !usage.primaryRole || typeof usage.primaryRole !== 'string') {
    return 'A skilled mercenary ready to support the team.';
  }
  const description = usage.primaryRole;
  if (description.length <= 150) return description;
  const truncated = description.substring(0, 150);
  const lastSpace = truncated.lastIndexOf(' ');
  return lastSpace > 0 ? truncated.substring(0, lastSpace) + '...' : truncated + '...';
}

const mercenaryImageKeyMap: Record<string, string> = {
  'Puppy Shooter': 'Puppy_Shooter.jpg',
  'Puppy Stepper': 'Puppy_Stepper.jpg',
  'Grrik': 'Grrik_Mercenary.jpg',
  'Koblod': 'Koblod_Mercenary.jpg',
  'Kobold': 'Koblod_Mercenary.jpg',
  'Goliath': 'Goliath.jpg',
  'Wizard Legionnaire': 'Wizard_Legionnaire.jpg',
  'War Mercenary': 'War_Mercenary.jpg',
  'Torta Warrior': 'Torta_warrior.jpg',
  'Imperial Shieldbearer': 'Imperial_Shieldbearer_Mercenary.jpg',
  'Split Twigs Priest': 'Split_Twigs_Priest.jpg',
  'Swamp Elf Vigilante': 'Swamp_Elf_Vigilante_member.jpg',
  'Headless Knight': 'Headless_Knight.jpg',
};

const mercenaryImageKey = mercenaryImageKeyMap[mercenaryData.name] || `${mercenaryData.name.replace(/ /g, '_')}.jpg`;
const mercenaryImageBaseName = mercenaryImageKey.replace('.jpg', '');
---

<!-- Mercenary Header & Overview -->
<section class="content-section character-overview-section">
  <div class="character-overview-flex">
    <!-- Hero Card (Left) - Full Body Portrait -->
    <div class="character-hero-card">
      <div class="character-portrait-fullbody">
        <div class="character-portrait-img-wrapper">
          <CharacterFullBodyImage
            imageName={mercenaryImageKey}
            alt={`${mercenaryData.name} - ${mercenaryData.rarity} rarity mercenary from Horizon Walker`}
            loading="eager"
            format="webp"
            quality={90}
            class="hw-character-fullbody"
          />
          <CrystalIcon characterImage={mercenaryImageBaseName} alt={`${mercenaryData.name} Future Crystal`} size={48} class="crystal-icon-portrait" />
          <div class="character-portrait-overlay"></div>
          <div class="character-portrait-info">
            <h1 class="character-name">{mercenaryData.name}</h1>
            <div class="character-portrait-badges">
              <HWRarityIcon rarity={mercenaryData.rarity} width={56} height={28} />
              <span class="hw-badge" data-type="Cost">Cost {mercenaryData.cost}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="character-info-card">
        <p class="character-description">
          {getMercenaryDescription(mercenaryData.usage)}
        </p>
      </div>
    </div>

    <!-- Complete Stats Box (Right) -->
    <div class="character-stats-container">
      <div class="character-stats-box">
        <div class="character-stats-header">
          <h3 class="character-stats-title">Base Stats</h3>
          <p class="character-stats-explanation">Stats shown at max level</p>
        </div>

        <div class="character-stats-subtitle">Core Stats</div>
        <div class="core-stats-explanation">
          <span><span class="stat-name">STR</span> Melee ATK</span>
          <span><span class="stat-name">TEC</span> Ranged ATK</span>
          <span><span class="stat-name">INT</span> Magic ATK</span>
          <span><span class="stat-name">VIT</span> Max HP</span>
          <span><span class="stat-name">AGI</span> Evasion & AP Rec.</span>
        </div>
        <div class="stats-core-row">
          <div class="stats-core-item">
            <div class="stats-core-value">{formatStat(mercenaryData.stats.strength)}</div>
            <div class="stats-core-label">STR</div>
          </div>
          <div class="stats-core-item">
            <div class="stats-core-value">{formatStat(mercenaryData.stats.technic)}</div>
            <div class="stats-core-label">TEC</div>
          </div>
          <div class="stats-core-item">
            <div class="stats-core-value">{formatStat(mercenaryData.stats.intelligence)}</div>
            <div class="stats-core-label">INT</div>
          </div>
          <div class="stats-core-item">
            <div class="stats-core-value">{formatStat(mercenaryData.stats.vitality)}</div>
            <div class="stats-core-label">VIT</div>
          </div>
          <div class="stats-core-item">
            <div class="stats-core-value">{formatStat(mercenaryData.stats.agility)}</div>
            <div class="stats-core-label">AGI</div>
          </div>
        </div>

        <div class="character-stats-subtitle">Combat</div>
        <div class="stats-table">
          <div class="stats-row">
            <span class="stats-row-label">Max HP</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.maxHp)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Melee ATK</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.meleeAtk)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Ranged ATK</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.rangedAtk)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Magic ATK</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.magicAtk)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Speed</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.spd)}</span>
          </div>
          <div class="stats-row" title="Base AP is 100. The value shown is the total, so Starting AP of 145 means +45 bonus AP at round 1.">
            <span class="stats-row-label">Starting AP<sup class="stats-note">*</sup></span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.startingAp)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">AP Recovery</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.apRecovery)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Accuracy</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.accuracy)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Evade</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.evade)}</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Crit Rate</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.critRate)}%</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Crit DMG</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.critDmg)}%</span>
          </div>
          <div class="stats-row">
            <span class="stats-row-label">Block Rate</span>
            <span class="stats-row-value">{formatStat(mercenaryData.stats.blockRate)}</span>
          </div>
        </div>
        <p class="stats-footnote">* Starting AP includes a base of 100. A value of 145 means +45 bonus AP at round 1 (only the amount above 100 is the increase).</p>

        <div class="character-stats-subtitle">Attributes</div>
        <div class="stats-attr-table">
          <div class="stats-attr-header">
            <span></span>
            <span class="stats-attr-col">Boost</span>
            <span class="stats-attr-col">DEF</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Slash</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.slashBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.slashDef)}</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Pierce</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.pierceBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.pierceDef)}</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Crush</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.crushBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.crushDef)}</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Heat</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.heatBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.heatDef)}</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Cold</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.coldBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.coldDef)}</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Electric</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.electricBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.electricDef)}</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Immaterial</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.immaterialBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.immaterialDef)}</span>
          </div>
          <div class="stats-attr-row">
            <span class="stats-attr-label">Poison</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.poisonBoost)}</span>
            <span class="stats-attr-value">{formatStat(mercenaryData.stats.poisonDef)}</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Skills Section -->
<section class="content-section skills-section">
  <h2 class="section-title">Skills</h2>
  <p class="skills-explanation">All skills shown at maximum level</p>

  {
    mercenaryData.skills &&
      mercenaryData.skills.map(skill => (
        <div class={`skill-card ${skill.type === 'Passive' ? 'passive-skill' : ''}`}>
          <div class="skill-header">
            <h3 class="skill-title">{skill.name}</h3>
            <div class="skill-meta">
              {skill.type === 'Passive' ? (
                <span class="skill-type-label passive-label">Passive</span>
              ) : (
                <span class="skill-type-label skill-label">Skill</span>
              )}
              {skill.type !== 'Passive' && skill.apCost != null && skill.apCost > 0 && (
                <span class="skill-cost">AP {skill.apCost}</span>
              )}
              {skill.type !== 'Passive' && skill.cooldown != null && skill.cooldown !== '0R' && (
                <span class="skill-cooldown">CD {skill.cooldown.replace('R', '')}</span>
              )}
            </div>
          </div>
          <p class="skill-description">{skill.description}</p>
          {skill.damage && (
            <div class="skill-damage">
              <span class="damage-label">Damage:</span>{' '}
              <span class="damage-value">{skill.damage}</span>
            </div>
          )}
        </div>
      ))
  }
</section>

<!-- Unique Traits Section -->
{
  mercenaryData.traits && (
    <section class="content-section traits-section">
      <h2 class="section-title">Unique Traits</h2>
      <div class="trait-system-note">
        <strong>Trait System:</strong> Unique and general traits can be obtained randomly in
        mercenaries. General traits only can be moved or removed. You want to get good unique traits
        for your mercenaries! Some mercenaries have 1 or more fixed unique traits.
      </div>

      {(() => {
        const traits = mercenaryData.traits || {};
        return Object.keys(traits).map(key => {
          const trait = traits[key] as Trait;
          return (
            <div class="trait-card">
              <div class="trait-header">
                <h3 class="trait-title">{trait.name}</h3>
                <span class="hw-badge" data-type="Trait">
                  Trait
                </span>
              </div>
              <p class="trait-description">{trait.description}</p>
              {trait.characteristics && (
                <div class="trait-characteristics">
                  <strong>Characteristics:</strong> {trait.characteristics}
                </div>
              )}
              {trait.notes && (
                <div class="trait-notes">
                  <em>Note: {trait.notes}</em>
                </div>
              )}
            </div>
          );
        });
      })()}
    </section>
  )
}
