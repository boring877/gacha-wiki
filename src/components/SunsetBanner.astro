---
// Site-wide sunset notice. Appears above the header on every page.
// Dismissible per-browser via localStorage. Rendered from Header.astro.
import '../styles/components/sunset-banner.css';
import { SITE } from '../consts';
---

<div class="sunset-banner" id="sunset-banner" role="alert">
  <span>
    <strong>GachaWiki is shutting down.</strong>
    Due to rising hosting costs and the time required to maintain it, the site
    will go offline on <strong>July 16, 2026</strong> (1 month from now).
  </span>
  <a class="sunset-link" href={SITE.SOCIAL.DISCORD} target="_blank" rel="noopener noreferrer">Learn more</a>
  <button class="sunset-close" type="button" aria-label="Dismiss notice">&times;</button>
</div>

<script is:inline define:vars={{ storageKey: 'gw_sunset_dismissed_v1' }}>
  (function () {
    var banner = document.getElementById('sunset-banner');
    if (!banner) return;
    try {
      if (localStorage.getItem(storageKey) === '1') {
        banner.classList.add('is-hidden');
        return;
      }
    } catch (e) {}
    var close = banner.querySelector('.sunset-close');
    if (close) {
      close.addEventListener('click', function () {
        banner.classList.add('is-hidden');
        try {
          localStorage.setItem(storageKey, '1');
        } catch (e) {}
      });
    }
  })();
</script>
