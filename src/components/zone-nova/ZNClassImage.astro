---
// Zone Nova class icon component
// Maps Zone Nova class names to the current public class icon assets.

const classImageMap = {
  Attacker: '/images/games/zone-nova/classes/Warrior.png',
  Warrior: '/images/games/zone-nova/classes/Warrior.png',
  Destroyer: '/images/games/zone-nova/classes/Destroyer.png',
  Guardian: '/images/games/zone-nova/classes/Tank.png',
  Tank: '/images/games/zone-nova/classes/Tank.png',
  Buffer: '/images/games/zone-nova/classes/Supporter.png',
  Supporter: '/images/games/zone-nova/classes/Supporter.png',
  Healer: '/images/games/zone-nova/classes/Healer.png',
  Debuffer: '/images/games/zone-nova/classes/Disruptor.png',
  Disruptor: '/images/games/zone-nova/classes/Disruptor.png',
  Mage: '/images/games/zone-nova/classes/Destroyer.png',
  Rogue: '/images/games/zone-nova/classes/Attacker.png',
};

interface Props {
  className: string;
  alt: string;
  size?: 'small' | 'medium' | 'large';
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  className,
  alt,
  size,
  width,
  height,
  class: classNameProp = '',
  loading = 'lazy',
} = Astro.props;

// Size presets for class icons
const sizePresets = {
  small: { width: 24, height: 24 },
  medium: { width: 48, height: 48 },
  large: { width: 80, height: 80 },
};

// Use size preset if provided, otherwise use explicit dimensions
const dimensions = size ? sizePresets[size] : { width: width || 48, height: height || 48 };

const imageSrc = classImageMap[className] || classImageMap.Warrior;
---

<img
  src={imageSrc}
  alt={alt}
  width={dimensions.width}
  height={dimensions.height}
  class={classNameProp}
  loading={loading}
  decoding="async"
/>
