const {
  imageName,
  alt,
  width = 300,
  height = 300,
  class: className = '',
  loading = 'lazy',
  format = 'webp',
  quality = 95,
} = Astro.props;

// Generate descriptive alt text if not provided
const generateAltText = (imageKey: string) => {
  const characterName = imageKey
    .replace(/\.(jpg|png)$/i, '')
    .replace(/([A-Z])/g, ' $1')
    .trim();
  return `${characterName} - Zone Nova character portrait and artwork`;
};

// Process image key and get the imported image object from the map
const processedImageKey = (() => {
  let key = imageName;
  if (key.includes('/')) {
    const parts = key.split('/');
    key = parts[parts.length - 1] || 'Afrodite.jpg';
  }
  if (!key.includes('.')) {
    key = `${key}.jpg`;
  }
  return key;
})();

const finalAlt = alt || generateAltText(processedImageKey);
const imageSrc = characterImageMap[processedImageKey] || null;
const placeholderSrc = '/images/placeholder.png';
---

{
  imageSrc && typeof imageSrc !== 'string' ? (
    <Image
      src={imageSrc}
      alt={finalAlt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      format={format}
      quality={quality}
    />
  ) : imageSrc ? (
    <img
      src={imageSrc}
      alt={finalAlt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding="async"
    />
  ) : (
    <img
      src={placeholderSrc}
      alt={finalAlt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding="async"
    />
  )
}
