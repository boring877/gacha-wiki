---
// Arcana portrait image component for Star Savior
// Looks up arcana small portrait by imageSmall filename
// Images are banner-style (480x264, ~1.82:1 ratio)
import { Image } from 'astro:assets';

const arcanaImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/games/star-savior/arcana/*.png',
  { eager: true }
);

export interface Props {
  imageSmall: string;
  alt: string;
  width?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  imageSmall,
  alt,
  width = 240,
  class: className,
  loading = 'lazy',
} = Astro.props;

function findImage(filename: string): ImageMetadata | null {
  if (!filename) return null;
  const key = Object.keys(arcanaImages).find(k =>
    k.endsWith('/' + filename)
  );
  return key ? arcanaImages[key].default : null;
}

const imageModule = findImage(imageSmall);
---

{imageModule ? (
  <div class={`ss-arcana-image-wrapper ${className || ''}`} style={`--arcana-img-width: ${width}px`}>
    <Image
      src={imageModule}
      alt={alt}
      width={width}
      height={Math.round(width / 1.82)}
      loading={loading}
      format="webp"
      quality={95}
      class="ss-arcana-image"
    />
  </div>
) : (
  <div class={`ss-arcana-image-fallback ${className || ''}`}>
    <span>{alt[0] || '?'}</span>
  </div>
)}

<style>
  .ss-arcana-image-wrapper {
    width: var(--arcana-img-width, 240px);
    max-width: 100%;
    border-radius: 6px;
    background: var(--ss-bg-tertiary);
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ss-arcana-image-wrapper :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
  }

  .ss-arcana-image-fallback {
    width: var(--arcana-img-width, 240px);
    max-width: 100%;
    aspect-ratio: 1.82 / 1;
    border-radius: 6px;
    background: var(--ss-bg-tertiary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--ss-text-muted);
  }
</style>
