---
// Arcana image component for Star Savior
// Supports both full-body card images (image) and small banner images (imageSmall)
// Full-body: card-style (704x1314, ~0.536:1 ratio)
// Small: banner-style (480x264, ~1.82:1 ratio)
import { Image } from 'astro:assets';

const arcanaImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/games/star-savior/arcana/*.png',
  { eager: true }
);

export interface Props {
  image?: string;
  imageSmall?: string;
  alt: string;
  width?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  image,
  imageSmall,
  alt,
  width = 240,
  class: className,
  loading = 'lazy',
} = Astro.props;

const filename = image || imageSmall || '';
const isCard = !!image && !imageSmall;

function findImage(fname: string): ImageMetadata | null {
  if (!fname) return null;
  const key = Object.keys(arcanaImages).find(k =>
    k.endsWith('/' + fname)
  );
  return key ? arcanaImages[key].default : null;
}

const imageModule = findImage(filename);
const aspectRatio = isCard ? 0.536 : 1.82;
---

{imageModule ? (
  <div class={`ss-arcana-image-wrapper ${className || ''}`} style={`--arcana-img-width: ${width}px`}>
    <Image
      src={imageModule}
      alt={alt}
      width={width}
      height={Math.round(width / aspectRatio)}
      loading={loading}
      format="webp"
      quality={95}
      class="ss-arcana-image"
    />
  </div>
) : (
  <div class={`ss-arcana-image-fallback ${className || ''}`} style={`--arcana-img-width: ${width}px`}>
    <span>{alt[0] || '?'}</span>
  </div>
)}

<style>
  .ss-arcana-image-wrapper {
    width: var(--arcana-img-width, 240px);
    max-width: 100%;
    border-radius: 6px;
    background: var(--ss-bg-tertiary);
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ss-arcana-image-wrapper :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
  }

  .ss-arcana-image-fallback {
    aspect-ratio: 1.82 / 1;
    border-radius: 6px;
    background: var(--ss-bg-tertiary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--ss-text-muted);
  }
</style>
