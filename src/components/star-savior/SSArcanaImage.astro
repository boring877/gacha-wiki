---
import { Image } from 'astro:assets';

const arcanaImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/games/star-savior/arcana/*.png',
  { eager: true }
);

const pieceImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/games/star-savior/arcana-pieces/*.png',
  { eager: true }
);

export interface Props {
  image?: string;
  imageSmall?: string;
  pieceImage?: string;
  alt: string;
  width?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  image,
  imageSmall,
  pieceImage,
  alt,
  width = 240,
  class: className,
  loading = 'lazy',
} = Astro.props;

const filename = image || imageSmall || '';
const isCard = !!image && !imageSmall;

function findImage(map: Record<string, { default: ImageMetadata }>, fname: string): ImageMetadata | null {
  if (!fname) return null;
  const key = Object.keys(map).find(k =>
    k.endsWith('/' + fname)
  );
  return key ? map[key].default : null;
}

const imageModule = findImage(arcanaImages, filename);
const pieceModule = findImage(pieceImages, pieceImage || '');
const aspectRatio = isCard ? 0.536 : 1.82;
---

{imageModule ? (
  <div class={`ss-arcana-image-wrapper ${className || ''}`} style={`--arcana-img-width: ${width}px`}>
    <Image
      src={imageModule}
      alt={alt}
      width={width}
      height={Math.round(width / aspectRatio)}
      loading={loading}
      format="webp"
      quality={95}
      class="ss-arcana-image"
    />
    {pieceModule && (
      <div class="ss-arcana-piece-badge">
        <Image
          src={pieceModule}
          alt=""
          width={Math.round(width * 0.32)}
          height={Math.round(width * 0.32)}
          loading={loading}
          format="webp"
          quality={90}
          class="ss-arcana-piece-img"
        />
      </div>
    )}
  </div>
) : (
  <div class={`ss-arcana-image-fallback ${className || ''}`} style={`--arcana-img-width: ${width}px`}>
    <span>{alt[0] || '?'}</span>
  </div>
)}

<style>
  .ss-arcana-image-wrapper {
    width: var(--arcana-img-width, 240px);
    max-width: 100%;
    border-radius: 6px;
    background: var(--ss-bg-tertiary);
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ss-arcana-image-wrapper :global(img.ss-arcana-image) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
  }

  .ss-arcana-piece-badge {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 32%;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.7)) drop-shadow(0 0 2px rgba(0, 0, 0, 0.5));
    pointer-events: none;
    z-index: 2;
  }

  .ss-arcana-piece-badge :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .ss-arcana-image-fallback {
    aspect-ratio: 1.82 / 1;
    border-radius: 6px;
    background: var(--ss-bg-tertiary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--ss-text-muted);
  }
</style>
