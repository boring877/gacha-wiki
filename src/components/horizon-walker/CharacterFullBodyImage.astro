export interface Props {
  imageName: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  format?: 'webp' | 'jpg' | 'png';
  quality?: number;
}

const {
  imageName,
  alt,
  class: className,
  loading = 'eager',
  format = 'webp',
  quality = 90,
} = Astro.props;

let imageKey = imageName;
if (!imageKey.includes('.')) {
  imageKey = `${imageKey}.jpg`;
}
const imageSrc = characterImageMap[imageKey];
---

<Image
  src={imageSrc}
  alt={alt}
  class={className}
  loading={loading}
  format={format}
  quality={quality}
/>
