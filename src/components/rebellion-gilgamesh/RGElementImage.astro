---
// Rebellion Gilgamesh element icon image component
// Displays element icons from assets/images/games/rebellion-gilgamesh/element/
import { Image } from 'astro:assets';

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/games/rebellion-gilgamesh/element/*.png',
  { eager: true }
);

export interface Props {
  element: number;
  alt: string;
  width?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const { element, alt, width = 32, class: className, loading = 'lazy' } = Astro.props;

const elementMap: Record<number, string> = {
  0: 'none.png',
  1: 'fire.png',
  2: 'water.png',
  3: 'wood.png',
  4: 'chaos.png',
  5: 'light.png',
  6: 'dark.png',
};

function findImage(fname: string): ImageMetadata | null {
  if (!fname) return null;
  const key = Object.keys(images).find(k => k.endsWith('/' + fname));
  return key ? images[key].default : null;
}

const imageModule = findImage(elementMap[element] || '');
---

{imageModule ? (
  <div class={`rg-element-wrapper ${className || ''}`} style={`--rg-element-width: ${width}px`}>
    <Image
      src={imageModule}
      alt={alt}
      width={width}
      height={width}
      loading={loading}
      format="webp"
      quality={90}
      class="rg-element-img"
    />
  </div>
) : (
  <div class={`rg-element-fallback ${className || ''}`} style={`--rg-element-width: ${width}px`}>
    <span>{alt[0] || '?'}</span>
  </div>
)}

<style>
  .rg-element-wrapper {
    width: var(--rg-element-width, 32px);
    height: var(--rg-element-width, 32px);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rg-element-wrapper :global(img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .rg-element-fallback {
    width: var(--rg-element-width, 32px);
    height: var(--rg-element-width, 32px);
    border-radius: var(--rg-radius-sm, 4px);
    background: var(--rg-bg-tertiary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: var(--rg-text-muted);
  }
</style>
