---
import HomeLayout from '../layouts/HomeLayout.astro';
import DecorativeLines from '../components/DecorativeLines.astro';
import { SITE_TITLE } from '../consts';
---

<HomeLayout
  title={`${SITE_TITLE} - Apps`}
  description="Download community tools built for the GachaWiki ecosystem.">
  <div class="apps-page">
    <header class="apps-header">
      <h1 class="apps-title">Apps</h1>
      <DecorativeLines />
      <p class="apps-subtitle">Tools built for the GachaWiki community.</p>
    </header>

    <div class="apps-list">

      <article class="app-card">
        <div class="app-card-body">
          <div class="app-info">
            <h2 class="app-name">Voice Type</h2>
            <p class="app-desc">Speech to text.</p>
            <span class="app-tag">v0.2.0</span>
          </div>
          <div class="app-downloads">
            <a href="https://github.com/boring877/voice_type_rust/releases/download/v0.2.0/Voice.Type_0.2.0_x64-setup.exe" class="dl-btn dl-btn-primary" target="_blank" rel="noopener noreferrer" download>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Windows
            </a>
            <a href="https://apps.microsoft.com/detail/9nqc232mwhzk?hl=en-US&gl=US" class="dl-btn dl-btn-secondary" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
              Microsoft Store
            </a>
            <a href="https://github.com/boring877/voice_type_rust" class="dl-btn dl-btn-ghost" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 22.792 24 18.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              Source
            </a>
          </div>
        </div>
      </article>

      <article class="app-card">
        <div class="app-card-body">
          <div class="app-info">
            <h2 class="app-name">SAB Data Extractor</h2>
            <p class="app-desc">Extract character stats, skills, images, and stories from Silver and Blood game files.</p>
            <span class="app-tag">v0.3.2</span>
          </div>
          <div class="app-downloads">
            <a href="https://github.com/boring877/sab-extractor/releases/download/v0.3.2/SAB.Data.Extractor_0.3.1_x64-setup.exe" class="dl-btn dl-btn-primary" target="_blank" rel="noopener noreferrer" download>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Windows
            </a>
            <a href="https://github.com/boring877/sab-extractor" class="dl-btn dl-btn-ghost" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 22.792 24 18.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              Source
            </a>
          </div>
        </div>
      </article>

    </div>
  </div>

  <style>
    @import '../styles/pages/apps.css';
  </style>
</HomeLayout>
