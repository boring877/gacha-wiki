---
// Taimanin Squad Tier List Page
// Unified tier list, all elements visible on one page
// Only released SR/SR+/SSR characters

import TierListLayout from '../../../../layouts/taimanin-squad/TierListLayout.astro';
import TSCharacterImage from '../../../../components/taimanin-squad/TSCharacterImage.astro';
import TSTypeIcon from '../../../../components/taimanin-squad/TSTypeIcon.astro';
import TSRoleIcon from '../../../../components/taimanin-squad/TSRoleIcon.astro';
import {
  buildTierList,
  TIER_DEFINITIONS,
  TIER_ORDER,
  TIER_BG,
  ELEMENTS,
  getTotalReleasedCount,
} from '../../../../data/taimanin-squad/tier-list-v2.js';

const tierData = buildTierList();
const totalChars = getTotalReleasedCount();

const STAR_MAP = { 'SSR': '★★★★★', 'SR+': '★★★★', 'SR': '★★★', 'R+': '★★', 'R': '★' };
const STAR_COUNT = { 'SSR': 5, 'SR+': 4, 'SR': 3, 'R+': 2, 'R': 1 };

const pageTitle = 'Tier List - Taimanin Squad Wiki | GachaWiki';
const pageDescription = `Complete tier list for ${totalChars} characters in Taimanin Squad. Rankings organized by element: Power, Technique, Agility, Balance.`;
---

<TierListLayout
  title={pageTitle}
  description={pageDescription}
  gameTitle="Tier List"
>
  <div class="tier-list-container">
    {Object.entries(tierData).map(([elementName, data]) => (
      <section class="ts-tl-section">
        <div class="ts-tl-section-header">
          <TSTypeIcon type={elementName} size={24} />
          <h3 class="ts-tl-section-title">{elementName}</h3>
          <span class="ts-tl-section-count">{data.total} characters</span>
        </div>

        <div class="tier-list-grid">
          {TIER_ORDER.map(tier => {
            const chars = data.tiers[tier];
            if (!chars || chars.length === 0) return null;
            return (
              <div class={`tier-row tier-${tier.toLowerCase()}`}>
                <div
                  class="tier-label"
                  style={`color: ${TIER_DEFINITIONS[tier].color}`}
                >
                  <span class="tier-name">{tier}</span>
                </div>
                <div class="tier-characters">
                  {chars.map(char => (
                    <div class="character-card" title={char.names?.english}>
                      <TSCharacterImage
                        icon={char.icon}
                        alt={char.names?.english || 'Character'}
                        width={64}
                        height={64}
                      />
                      <span class={`ts-badge-stars stars-${STAR_COUNT[char.rarity] || 3}`}>
                        {STAR_MAP[char.rarity] || char.rarity}
                      </span>
                      <span class="character-name">{char.names?.english}</span>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ))}

   </div>
</TierListLayout>
