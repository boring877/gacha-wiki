---
// Taimanin Squad Buff/Debuff Database Page
// Displays all buff and debuff effects with icons, official game descriptions, and value ranges

import BuffDebuffLayout from '../../../../layouts/taimanin-squad/BuffDebuffLayout.astro';
import TSBuffIcon from '../../../../components/taimanin-squad/TSBuffIcon.astro';
import { TS_BUFFS_DEBUFFS, TS_BUFF_DEBUFF_CATEGORIES } from '../../../../data/taimanin-squad/ts-buffs-debuffs';
import buffData from '../../../../data/taimanin-squad/buff_data.json';
import debuffData from '../../../../data/taimanin-squad/debuff_data.json';

interface RawEntry {
  Type: string;
  Value2_Duration: number;
  Value3_Percent: number;
}

interface ValueRange {
  min: number;
  max: number;
}

type ValueMap = Map<string, { durations: number[]; percents: number[] }>;

function buildValueMap(data: RawEntry[]): ValueMap {
  const map: ValueMap = new Map();
  for (const entry of data) {
    if (!map.has(entry.Type)) {
      map.set(entry.Type, { durations: [], percents: [] });
    }
    const agg = map.get(entry.Type)!;
    if (entry.Value2_Duration > 0) agg.durations.push(entry.Value2_Duration);
    if (entry.Value3_Percent !== 0) agg.percents.push(Math.abs(entry.Value3_Percent));
  }
  return map;
}

function getRange(values: number[]): ValueRange | null {
  if (!values.length) return null;
  return { min: Math.min(...values), max: Math.max(...values) };
}

function formatRange(range: ValueRange | null): string | null {
  if (!range) return null;
  if (range.min === range.max) return `${range.min}`;
  return `${range.min} - ${range.max}`;
}

const buffValues = buildValueMap(buffData as RawEntry[]);
const debuffValues = buildValueMap(debuffData as RawEntry[]);

function getValueRange(type: string): { duration: ValueRange | null; effect: ValueRange | null } {
  const source = buffValues.has(type) ? buffValues : debuffValues;
  const agg = source.get(type);
  if (!agg) return { duration: null, effect: null };
  return {
    duration: getRange(agg.durations),
    effect: getRange(agg.percents),
  };
}

const effects = TS_BUFFS_DEBUFFS.map(e => ({
  ...e,
  ...getValueRange(e.id),
}));

const buffs = effects.filter(e => e.group === 'buff');
const debuffs = effects.filter(e => e.group === 'debuff');

const categories = Object.values(TS_BUFF_DEBUFF_CATEGORIES);
---

<BuffDebuffLayout
  title="Buffs & Debuffs - Taimanin Squad Wiki | GachaWiki"
  description="Complete database of all buff and debuff effects in Taimanin Squad with icons, descriptions, and value ranges."
  gameTitle="Buffs & Debuffs"
>
  <div class="ts-bd-summary">
    <div class="ts-bd-summary-item ts-bd-summary-buff">
      <span class="ts-bd-summary-count">{buffs.length}</span>
      <span class="ts-bd-summary-label">Buffs</span>
    </div>
    <div class="ts-bd-summary-item ts-bd-summary-debuff">
      <span class="ts-bd-summary-count">{debuffs.length}</span>
      <span class="ts-bd-summary-label">Debuffs</span>
    </div>
  </div>

  <div class="ts-tabs">
    <button class="ts-tab active" data-tab="buffs">Buffs</button>
    <button class="ts-tab" data-tab="debuffs">Debuffs</button>
    <button class="ts-tab" data-tab="all">All Effects</button>
  </div>

  {[
    { id: 'buffs', items: buffs },
    { id: 'debuffs', items: debuffs },
    { id: 'all', items: effects },
  ].map(({ id, items }) => (
    <div class="ts-tab-content active" id={`${id}-content`}>
      {categories.map(cat => {
        const catItems = items.filter(e => e.category === cat);
        if (!catItems.length) return null;
        return (
          <div class="ts-bd-category">
            <h2 class="ts-bd-category-title">{cat}</h2>
            <div class="ts-effect-grid">
              {catItems.map(effect => (
                <div class="ts-effect-card">
                  <div class="ts-effect-header">
                    <div class="ts-effect-icon">
                      <TSBuffIcon icon={effect.icon} alt={effect.name} width={48} height={48} />
                    </div>
                    <div class="ts-effect-info">
                      <h3 class="ts-effect-name">{effect.name}</h3>
                      <p class="ts-effect-desc">{effect.description}</p>
                    </div>
                  </div>
                  <div class="ts-effect-details">
                    {effect.hasDuration && effect.duration && (
                      <span class="ts-detail-tag">Duration: {formatRange(effect.duration)} turn{effect.duration.min > 1 ? 's' : ''}</span>
                    )}
                    {effect.hasValue && effect.effect && (
                      <span class="ts-detail-tag">Effect: {formatRange(effect.effect)}%</span>
                    )}
                    <span class="ts-detail-tag ts-detail-type">{"Buff"}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  ))}
</BuffDebuffLayout>

<script define:vars={{ effects }}>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.ts-tab');
    const contents = document.querySelectorAll('.ts-tab-content');

    function setDetailTagTypes(tabId) {
      const typeMap = {
        buffs: 'Buff',
        debuffs: 'Debuff',
        all: null,
      };
      document.querySelectorAll('.ts-detail-type').forEach(el => {
        if (!typeMap[tabId]) {
          const card = el.closest('.ts-effect-card');
          if (card) {
            const name = card.querySelector('.ts-effect-name')?.textContent || '';
            const effect = effects.find(e => e.name === name);
            el.textContent = effect?.group === 'buff' ? 'Buff' : 'Debuff';
          }
        } else {
          el.textContent = typeMap[tabId];
        }
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        const tabId = tab.getAttribute('data-tab');
        const content = document.getElementById(`${tabId}-content`);
        if (content) content.classList.add('active');
        setDetailTagTypes(tabId);
      });
    });

    setDetailTagTypes('buffs');
  });
</script>
