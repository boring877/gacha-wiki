              {skill.tips && skill.tips.length > 0 && (
                <div class="skill-tips">
                  <span class="tips-label">Mechanic:</span>
                  <div class="tips-list">
                    {skill.tips.map((tip: any) => (
                      <div class="tip-item">
                        <div class="tip-info">
                          <span class="tip-name">{tip.name}</span>
                          <p class="tip-desc">{tip.description}</p>
