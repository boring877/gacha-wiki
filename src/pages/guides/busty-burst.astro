---
import BustyBurstLandingLayout from '../../layouts/busty-burst/LandingLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { bustyBurstConfig } from '../../data/busty-burst/busty-burst.js';
import heroImg from '../../assets/images/games/Busty_Burst/BG/gameLogo.webp';

const { meta, gameInfo, gameNotes, categoryGroups } = bustyBurstConfig;
---

<BustyBurstLandingLayout
  title={meta.title}
  description={meta.description}
  gameTitle={meta.gameTitle}
  heroImage={heroImg}
>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Busty Burst Fantasy Wiki & Guide - Download, Global Version & Paladin Database",
      "url": "https://gachawiki.info/guides/busty-burst/",
      "description": "Download Busty Burst Fantasy global version - Complete paladin database, tier lists, summoning guides and lord system mechanics. Free download link, latest updates and team building strategies.",
      "publisher": {
        "@type": "Organization",
        "name": "GachaWiki",
        "url": "https://gachawiki.info"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://gachawiki.info/guides/busty-burst/characters/?search={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "VideoGame",
      "name": "Busty Burst Fantasy",
      "alternateName": ["巨乳ファンタジーバースト", "kyonyu burst", "busty burst"],
      "genre": ["Adult RPG", "Gacha", "Fantasy"],
      "description": "Adult fantasy RPG where Rufus, a lord from the frontier region, must summon powerful otherworldly paladins from the abandoned Goddess Ruin to save his lordship through strategic duels among subordinate paladins.",
      "keywords": "Busty Burst Fantasy, 巨乳ファンタジーバースト, kyonyu burst, download, global version, free download, adult gacha game, paladin summoning, lord system, duel combat, Rufus story, Kingdom of Vern, Goddess Ruin, otherworldly paladins",
      "applicationCategory": "Game",
      "operatingSystem": "Android, iOS",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      }
    }
  </script>

  <section class="content-section">
    <div class="game-description">
      <p>
        The online game Kyonyuu Fantasy Burst! (Busty Fantasy Burst!), adapted from the popular
        Japanese PC game series Kyonyuu Fantasy which has been going strong for over 10 years, is
        finally available in English!
      </p>
    </div>

    <div class="play-button-container">
      <a href={gameInfo.playUrl} target="_blank" class="play-button">
        Download & Play Busty Burst Fantasy
        <span class="play-arrow">→</span>
      </a>
    </div>

    <div class="bb-social-links-container">
      <div class="bb-social-links">
        <a
          href={gameInfo.discordUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bb-social-link"
          aria-label="Join Busty Burst Fantasy Discord"
        >
          Discord
        </a>
      </div>
    </div>

    <p class="last-updated">
      Last Updated: <FormattedDate date={gameInfo.lastUpdated} />
    </p>
  </section>

  <section class="game-notes-section">
    <h2 class="game-notes-title">{gameNotes.title}</h2>
    <div class="game-notes-list">
      {
        gameNotes.notes.map(note => (
          <div class="game-note-item">
            <h3 class="game-note-title">{note.title}</h3>
            <p class="game-note-content">{note.content}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bb-resources-section">
    <h2 class="bb-resources-title">Guides & Resources</h2>

    <div class="bb-resources-grid">
      {
        categoryGroups.map(category => (
          <div class={`bb-resource-category bb-category-${category.size}`}>
            <div class="bb-category-header">
              <h3>{category.title}</h3>
              <p class="bb-category-description">{category.description}</p>
            </div>
            <div class="bb-buttons-grid">
              {category.guides.map(guide => (
                <a
                  href={guide.url}
                  class="bb-resource-button"
                  aria-label={`Navigate to ${guide.title}`}
                >
                  {guide.title}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BustyBurstLandingLayout>
