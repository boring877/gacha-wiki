---
import RebellionGilgameshLandingLayout from '../../layouts/rebellion-gilgamesh/LandingLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { rebellionGilgameshConfig } from '../../data/rebellion-gilgamesh/rebellion-gilgamesh.js';

const { meta, gameInfo, story, categoryGroups } = rebellionGilgameshConfig;
---

<RebellionGilgameshLandingLayout
  title={meta.title}
  description={meta.description}
  gameTitle={meta.gameTitle}
  heroImage={meta.heroImage}
>
  <!-- FAQPage + BreadcrumbList Structured Data (VideoGame/WebSite are in RGBaseHead) -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'FAQPage',
          mainEntity: [
            {
              '@type': 'Question',
              name: 'What is Rebellion Gilgamesh?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'Rebellion Gilgamesh is an adult fantasy RPG set in a demon-ruled world where players manage clubs and collect characters to save humanity.',
              },
            },
            {
              '@type': 'Question',
              name: 'Where can I download Rebellion Gilgamesh?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'You can download Rebellion Gilgamesh from Erolabs or DMM. The game is available for Android, iOS, and Web platforms.',
              },
            },
            {
              '@type': 'Question',
              name: 'What platforms support Rebellion Gilgamesh?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'Rebellion Gilgamesh is available on Android, iOS, and Web browsers with cross-platform progression.',
              },
            },
          ],
        },
        {
          '@type': 'BreadcrumbList',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Home',
              item: 'https://gachawiki.info',
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Rebellion Gilgamesh',
              item: 'https://gachawiki.info/guides/rebellion-gilgamesh/',
            },
          ],
        },
      ],
    })}
  />

  <!-- Hreflang tags for international SEO -->
  <link rel="alternate" hreflang="en" href="https://gachawiki.info/guides/rebellion-gilgamesh/" />
  <link rel="alternate" hreflang="ja" href="https://gachawiki.info/guides/rebellion-gilgamesh/" />
  <link
    rel="alternate"
    hreflang="x-default"
    href="https://gachawiki.info/guides/rebellion-gilgamesh/"
  />

  <!-- Game Overview Section -->
  <section class="content-section">
    <h2 class="section-title">Game Introduction</h2>
    <div class="story-content">
      {story.content.map(paragraph => paragraph ? <p>{paragraph}</p> : <br />)}
    </div>

    <div class="play-button-container">
      <a href={gameInfo.playUrl} target="_blank" class="play-button"> Play on Erolabs </a>
      <a href={gameInfo.socialLinks.dmm} target="_blank" class="play-button"> Play on DMM </a>
    </div>

    <div class="social-links-container">
      <h4>Game Social:</h4>
      <div class="social-links">
        <a
          href={gameInfo.socialLinks.twitter}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Follow Rebellion Gilgamesh on Twitter/X"
        >
          Twitter/X
        </a>
      </div>
    </div>

    <p class="last-updated">
      Last Updated: <FormattedDate date={gameInfo.lastUpdated} />
    </p>
  </section>

  <!-- Resources Section -->
  <section class="content-section">
    <h2 class="section-title">Game Resources</h2>

    <div class="rg-resources-grid">
      {categoryGroups.map(category => (
        <div class={`rg-resource-category rg-category-${category.size}`}>
          <div class="rg-category-header">
            <h3>{category.title}</h3>
            <p class="rg-category-description">{category.description}</p>
          </div>
          <div class="rg-buttons-grid">
            {category.guides.map(guide => (
              <a
                href={guide.url}
                class="rg-resource-button"
                aria-label={`Navigate to ${guide.title}`}
              >
                {guide.title}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</RebellionGilgameshLandingLayout>
