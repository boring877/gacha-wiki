---
import ZoneNovaLayout from '../../../layouts/zone-nova/LandingLayout.astro';
import { summonFaqData } from '../../../data/zone-nova/summon-faq.js';
import '../../../styles/games/zone-nova/zn-summon-faq.css';
---

<ZoneNovaLayout
  title="Zone Nova Summon FAQ - Gacha Wiki"
  description="Complete FAQ guide for summoning in Zone Nova. Learn about rates, pity system, banners, and summoning strategies."
  gameTitle="Summon FAQ"
>
  <!-- FAQ Schema Markup -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are the SSR character summon rates in Zone Nova?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SSR characters have a 0.6% base rate and 1.6% effective rate with the pity system. You're guaranteed an SSR character within 90 summons maximum."
          }
        },
        {
          "@type": "Question",
          "name": "How does the pity system work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The pity system guarantees an SSR character within 90 summons on character banners and within 80 summons on memory banners. The effective rate includes this guarantee."
          }
        },
        {
          "@type": "Question",
          "name": "What is the rate-up system?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Rate-up banners give you a 50% chance to get the featured SSR character. If you get a non-featured SSR, your next SSR is guaranteed to be the featured one."
          }
        },
        {
          "@type": "Question",
          "name": "What are the SR summon rates?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SR objects have a 6% base rate (3% characters, 3% memories) and 13% effective rate with the pity system. You're guaranteed an SR+ within 10 summons."
          }
        },
        {
          "@type": "Question",
          "name": "How do duplicate characters work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Duplicate SSR characters give 20 Star Fragments (2nd-7th) or 40 Star Fragments (8th+). Duplicate SR characters give 5 Star Fragments (2nd-7th) or 10 Star Fragments (8th+)."
          }
        }
      ]
    }
  </script>
  <div class="faq-container">
    <section class="content-section">
      <h2 class="section-title">{summonFaqData.characterSummons.title}</h2>

      <h3 class="subsection-title">Character Summon Rates</h3>
      <div class="rate-note">
        <p>
          <strong>Note:</strong> The "effective rate" includes the pity system guarantee. For example,
          1.6% effective rate means when you include the fact that you're guaranteed an SSR within 90
          pulls maximum.
        </p>
      </div>
      <div class="rates-grid">
        <div class="rate-category">
          <h3>{summonFaqData.characterSummons.summonRates.ssrCharacters.title}</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value ssr"
                >{summonFaqData.characterSummons.summonRates.ssrCharacters.baseRate}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value ssr"
                >{summonFaqData.characterSummons.summonRates.ssrCharacters.effectiveRate}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value"
                >{summonFaqData.characterSummons.summonRates.ssrCharacters.guaranteed}</span
              >
            </div>

            <div class="rate-up-section">
              <h4 class="rate-up-title">SSR Rate-Up</h4>
              <div class="stat-item">
                <span class="stat-label">Chance:</span>
                <span class="stat-value rate-up">50% chance to get featured SSR character</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Guarantee:</span>
                <span class="stat-value rate-up"
                  >If non-featured SSR obtained, next SSR is guaranteed to be featured</span
                >
              </div>
            </div>
          </div>
        </div>

        <div class="rate-category">
          <h3>{summonFaqData.characterSummons.summonRates.srObjects.title}</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value sr"
                >{summonFaqData.characterSummons.summonRates.srObjects.baseRate}</span
              >
            </div>
            <div class="rate-breakdown">
              <div class="breakdown-item">
                <span class="breakdown-label">SR Characters:</span>
                <span class="breakdown-value"
                  >{
                    summonFaqData.characterSummons.summonRates.srObjects.breakdown.srCharacters
                  }</span
                >
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">SR Memories:</span>
                <span class="breakdown-value"
                  >{summonFaqData.characterSummons.summonRates.srObjects.breakdown.srMemories}</span
                >
              </div>
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value sr"
                >{summonFaqData.characterSummons.summonRates.srObjects.effectiveRate}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value"
                >{summonFaqData.characterSummons.summonRates.srObjects.guaranteed}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">SR+ Guarantee Rate:</span>
              <span class="stat-value small"
                >{summonFaqData.characterSummons.summonRates.srObjects.srGuaranteeRate}</span
              >
            </div>

            <div class="rate-up-section">
              <h4 class="rate-up-title">SR Character Rate-Up</h4>
              <div class="stat-item">
                <span class="stat-label">Chance:</span>
                <span class="stat-value rate-up"
                  >50% chance to get one of the featured SR characters</span
                >
              </div>
              <div class="stat-item">
                <span class="stat-label">Guarantee:</span>
                <span class="stat-value rate-up"
                  >If non-featured SR obtained, next SR is guaranteed to be one of the featured
                  characters</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">{summonFaqData.memorySummons.title}</h2>

      <h3 class="subsection-title">Memory Summon Rates</h3>
      <div class="rates-grid">
        <div class="rate-category">
          <h3>{summonFaqData.memorySummons.summonRates.ssrMemories.title}</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value ssr"
                >{summonFaqData.memorySummons.summonRates.ssrMemories.baseRate}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value ssr"
                >{summonFaqData.memorySummons.summonRates.ssrMemories.comprehensiveRate}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value"
                >{summonFaqData.memorySummons.summonRates.ssrMemories.guaranteed}</span
              >
            </div>

            <div class="rate-up-section">
              <h4 class="rate-up-title">SSR Memory Rate-Up</h4>
              <div class="stat-item">
                <span class="stat-label">Chance:</span>
                <span class="stat-value rate-up">75% chance to get featured SSR memory</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Guarantee:</span>
                <span class="stat-value rate-up"
                  >If non-featured SSR memory obtained, next SSR memory is guaranteed to be featured</span
                >
              </div>
            </div>
          </div>
        </div>

        <div class="rate-category">
          <h3>{summonFaqData.memorySummons.summonRates.srObjects.title}</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value sr"
                >{summonFaqData.memorySummons.summonRates.srObjects.baseRate}</span
              >
            </div>
            <div class="rate-breakdown">
              <div class="breakdown-item">
                <span class="breakdown-label">SR Characters:</span>
                <span class="breakdown-value"
                  >{summonFaqData.memorySummons.summonRates.srObjects.breakdown.srCharacters}</span
                >
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">SR Memories:</span>
                <span class="breakdown-value"
                  >{summonFaqData.memorySummons.summonRates.srObjects.breakdown.srMemories}</span
                >
              </div>
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value sr"
                >{summonFaqData.memorySummons.summonRates.srObjects.comprehensiveRate}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value"
                >{summonFaqData.memorySummons.summonRates.srObjects.guaranteed}</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">SR+ Guarantee Rate:</span>
              <span class="stat-value small"
                >{summonFaqData.memorySummons.summonRates.srObjects.srGuaranteeRate}</span
              >
            </div>

            <div class="rate-up-section">
              <h4 class="rate-up-title">SR Memory Rate-Up</h4>
              <div class="stat-item">
                <span class="stat-label">Chance:</span>
                <span class="stat-value rate-up"
                  >75% chance to get one of the featured SR memories</span
                >
              </div>
              <div class="stat-item">
                <span class="stat-label">Guarantee:</span>
                <span class="stat-value rate-up"
                  >If non-featured SR memory obtained, next SR memory is guaranteed to be one of the
                  featured memories</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">Regular Character Summons</h2>

      <h3 class="subsection-title">Regular Character Summon Rates</h3>
      <div class="rates-grid">
        <div class="rate-category">
          <h3>SSR Characters</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value ssr">0.6%</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value ssr">1.6%</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value">Within 90 summons maximum</span>
            </div>

            <div class="rate-up-section">
              <h4 class="rate-up-title">Character Selection System</h4>
              <div class="stat-item">
                <span class="stat-label">SSR Characters:</span>
                <span class="stat-value rate-up"
                  >100% chance to be one of the selectable characters with equal rates for each</span
                >
              </div>
            </div>
          </div>
        </div>

        <div class="rate-category">
          <h3>SR Memories</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value sr">6%</span>
            </div>
            <div class="rate-breakdown">
              <div class="breakdown-item">
                <span class="breakdown-label">SR Characters:</span>
                <span class="breakdown-value">3%</span>
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">SR Memories:</span>
                <span class="breakdown-value">3%</span>
              </div>
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value sr">13%</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value">Within 10 summons maximum</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">SR+ Guarantee Rate:</span>
              <span class="stat-value small">99.4% SR characters/memories, 0.6% SSR characters</span
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">Regular Memory Summons</h2>

      <h3 class="subsection-title">Regular Memory Summon Rates</h3>
      <div class="rates-grid">
        <div class="rate-category">
          <h3>SSR Memories</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value ssr">0.8%</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value ssr">1.87%</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value">Within 80 summons maximum</span>
            </div>

            <div class="rate-up-section">
              <h4 class="rate-up-title">Memory Selection System</h4>
              <div class="stat-item">
                <span class="stat-label">SSR Memories:</span>
                <span class="stat-value rate-up"
                  >100% chance to be one of the selectable memories with equal rates for each</span
                >
              </div>
            </div>
          </div>
        </div>

        <div class="rate-category">
          <h3>SR Memories</h3>
          <div class="rate-stats">
            <div class="stat-item">
              <span class="stat-label">Base Rate:</span>
              <span class="stat-value sr">9.1%</span>
            </div>
            <div class="rate-breakdown">
              <div class="breakdown-item">
                <span class="breakdown-label">SR Characters:</span>
                <span class="breakdown-value">4.55%</span>
              </div>
              <div class="breakdown-item">
                <span class="breakdown-label">SR Memories:</span>
                <span class="breakdown-value">4.55%</span>
              </div>
            </div>
            <div class="stat-item">
              <span class="stat-label">Effective Rate:</span>
              <span class="stat-value sr">14.8%</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Guaranteed:</span>
              <span class="stat-value">Within 10 summons maximum</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">SR+ Guarantee Rate:</span>
              <span class="stat-value small">99.2% SR characters/memories, 0.8% SSR memories</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">Conversion Systems Comparison</h2>

      <h3 class="subsection-title">Character Summon Conversion</h3>
      <div class="conversion-grid">
        <div class="conversion-category">
          <h3>Character Duplicate Rewards</h3>

          <div class="duplicate-type">
            <h4>
              {summonFaqData.characterSummons.conversionSystem.duplicateRewards.ssrCharacters.title}
            </h4>
            <div class="duplicate-rewards">
              <div class="reward-item">
                <span class="reward-label">2nd - 7th duplicate:</span>
                <span class="reward-value"
                  >{
                    summonFaqData.characterSummons.conversionSystem.duplicateRewards.ssrCharacters
                      .secondToSeventh
                  }</span
                >
              </div>
              <div class="reward-item">
                <span class="reward-label">8th+ duplicate:</span>
                <span class="reward-value"
                  >{
                    summonFaqData.characterSummons.conversionSystem.duplicateRewards.ssrCharacters
                      .eighthPlus
                  }</span
                >
              </div>
            </div>
          </div>

          <div class="duplicate-type">
            <h4>
              {summonFaqData.characterSummons.conversionSystem.duplicateRewards.srCharacters.title}
            </h4>
            <div class="duplicate-rewards">
              <div class="reward-item">
                <span class="reward-label">2nd - 7th duplicate:</span>
                <span class="reward-value"
                  >{
                    summonFaqData.characterSummons.conversionSystem.duplicateRewards.srCharacters
                      .secondToSeventh
                  }</span
                >
              </div>
              <div class="reward-item">
                <span class="reward-label">8th+ duplicate:</span>
                <span class="reward-value"
                  >{
                    summonFaqData.characterSummons.conversionSystem.duplicateRewards.srCharacters
                      .eighthPlus
                  }</span
                >
              </div>
            </div>
          </div>
        </div>

        <div class="conversion-category">
          <h3>{summonFaqData.characterSummons.conversionSystem.memoryRewards.title}</h3>
          <div class="memory-rewards">
            <div class="reward-item">
              <span class="reward-label">SR Memory:</span>
              <span class="reward-value"
                >{summonFaqData.characterSummons.conversionSystem.memoryRewards.srMemory}</span
              >
            </div>
            <div class="reward-item">
              <span class="reward-label">Rare Memory:</span>
              <span class="reward-value"
                >{summonFaqData.characterSummons.conversionSystem.memoryRewards.rareMemory}</span
              >
            </div>
          </div>
        </div>
      </div>

      <h3 class="subsection-title">Memory Summon Conversion</h3>
      <div class="conversion-grid">
        <div class="conversion-category">
          <h3>{summonFaqData.memorySummons.conversionSystem.memoryRewards.title}</h3>
          <div class="memory-rewards">
            <div class="reward-item">
              <span class="reward-label">SSR Memory:</span>
              <span class="reward-value"
                >{summonFaqData.memorySummons.conversionSystem.memoryRewards.ssrMemory}</span
              >
            </div>
            <div class="reward-item">
              <span class="reward-label">SR Memory:</span>
              <span class="reward-value"
                >{summonFaqData.memorySummons.conversionSystem.memoryRewards.srMemory}</span
              >
            </div>
            <div class="reward-item">
              <span class="reward-label">Rare Memory:</span>
              <span class="reward-value"
                >{summonFaqData.memorySummons.conversionSystem.memoryRewards.rareMemory}</span
              >
            </div>
          </div>
        </div>

        <div class="conversion-category">
          <h3>{summonFaqData.memorySummons.conversionSystem.duplicateCharacterRewards.title}</h3>
          <div class="duplicate-rewards">
            <div class="reward-item">
              <span class="reward-label">2nd - 7th duplicate:</span>
              <span class="reward-value"
                >{
                  summonFaqData.memorySummons.conversionSystem.duplicateCharacterRewards
                    .secondToSeventh
                }</span
              >
            </div>
            <div class="reward-item">
              <span class="reward-label">8th+ duplicate:</span>
              <span class="reward-value"
                >{
                  summonFaqData.memorySummons.conversionSystem.duplicateCharacterRewards.eighthPlus
                }</span
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-grid">
        {
          summonFaqData.faqItems.map(faq => (
            <div class="faq-item" id={`faq-${faq.id}`}>
              <div class="faq-question">
                <h3>{faq.question}</h3>
                <span class="faq-toggle">+</span>
              </div>
              <div class="faq-answer">
                <p>{faq.answer}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">Need More Help?</h2>
      <div class="help-links">
        {
          summonFaqData.helpLinks.map(link => (
            <a href={link.href} class="help-link">
              <span class="help-icon">{link.icon}</span>
              <span class="help-text">{link.text}</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</ZoneNovaLayout>

<script>
  // FAQ Toggle Functionality
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const toggle = item.querySelector('.faq-toggle') as HTMLElement;

      if (!question || !answer || !toggle) return;

      // Initially hide all answers
      answer.style.display = 'none';

      question.addEventListener('click', () => {
        const isActive = item.classList.contains('active');

        // Close all other FAQ items
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('active');
            const otherAnswer = otherItem.querySelector('.faq-answer') as HTMLElement;
            const otherToggle = otherItem.querySelector('.faq-toggle') as HTMLElement;
            if (otherAnswer) otherAnswer.style.display = 'none';
            if (otherToggle) otherToggle.textContent = '+';
          }
        });

        // Toggle current item
        if (isActive) {
          item.classList.remove('active');
          answer.style.display = 'none';
          toggle.textContent = '+';
        } else {
          item.classList.add('active');
          answer.style.display = 'block';
          toggle.textContent = '−';
        }
      });
    });
  });
</script>
