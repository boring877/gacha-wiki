---
import CharacterIndividualLayout from '../../../../layouts/zone-nova/CharacterIndividualLayout.astro';
import CharacterPageTemplate from '../../../../templates/zone-nova/CharacterPageTemplate.astro';
import { hiyoriData, hiyoriSEO } from '../../../../data/zone-nova/characters/hiyori.js';

export const prerender = true;
---

<CharacterIndividualLayout
  title={hiyoriSEO.title}
  description={hiyoriSEO.description}
  gameTitle={hiyoriData.name}
  character={hiyoriData}
>
  <CharacterPageTemplate characterData={hiyoriData} />
</CharacterIndividualLayout>
