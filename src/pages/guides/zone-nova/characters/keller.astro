---
import CharacterIndividualLayout from '../../../../layouts/zone-nova/CharacterIndividualLayout.astro';
import CharacterPageTemplate from '../../../../templates/zone-nova/CharacterPageTemplate.astro';
import { kellerData, kellerSEO } from '../../../../data/zone-nova/characters/keller.js';

export const prerender = true;
---

<CharacterIndividualLayout
  title={kellerSEO.title}
  description={kellerSEO.description}
  gameTitle={kellerData.name}
  character={kellerData}
>
  <CharacterPageTemplate characterData={kellerData} />
</CharacterIndividualLayout>
