---
import CharacterIndividualLayout from '../../../../layouts/zone-nova/CharacterIndividualLayout.astro';
import CharacterPageTemplate from '../../../../templates/zone-nova/CharacterPageTemplate.astro';
import { sharinData, sharinSEO } from '../../../../data/zone-nova/characters/sharin.js';

export const prerender = true;
---

<CharacterIndividualLayout
  title={sharinSEO.title}
  description={sharinSEO.description}
  gameTitle={sharinData.name}
  character={sharinData}
>
  <CharacterPageTemplate characterData={sharinData} />
</CharacterIndividualLayout>
