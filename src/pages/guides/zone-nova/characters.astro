---
// Import your layout
import CharacterLayout from '../../../layouts/zone-nova/CharacterLayout.astro';

// Import character database components
import CharacterDatabaseFilterBar from '../../../components/zone-nova/CharacterDatabaseFilterBar.astro';
import CharacterDatabaseTable from '../../../components/zone-nova/CharacterDatabaseTable.astro';
import CharacterDatabaseMobileCards from '../../../components/zone-nova/CharacterDatabaseMobileCards.astro';
import '../../../styles/games/zone-nova/zn-character.css';
---

<CharacterLayout
  title="Zone Nova Character Database - GachaWiki"
  description="Sortable and filterable character database for Zone Nova"
  gameTitle="Character Database"
  showBackButton={false}
>
  <section class="page-flex">
    <div class="main-content-container">
      <div class="content-wrapper">
        <!-- Character Database Components -->
        <CharacterDatabaseFilterBar />
        <CharacterDatabaseTable />
        <CharacterDatabaseMobileCards />
      </div>
    </div>
  </section>

  <!-- Import the database utilities -->
  <script>
    import { initializeCharacterDatabase } from '../../../data/zone-nova/character-database-utils.js';
    initializeCharacterDatabase();
  </script>
</CharacterLayout>
