---
import TierListLayout from '../../../layouts/zone-nova/TierListLayout.astro';
import { ZONE_NOVA_CHARACTERS } from '../../../data/zone-nova/characters.js';
import { ALL_TIER_LISTS, TIER_DEFINITIONS } from '../../../data/zone-nova/tier-lists.js';
import { ZNCharacterImage } from '../../../components/zone-nova/index.astro';

// Create a map of character data for quick lookup
const characterMap = {};
ZONE_NOVA_CHARACTERS.forEach(char => {
  characterMap[char.name] = char;
});

// Helper function to get tier class name
function getTierClassName(tier: string): string {
  return tier.toLowerCase().replace('+', '-plus').replace(/\s+/g, '-');
}
---

<TierListLayout
  title="Zone Nova Tier List - Character Rankings & Meta Guide"
  description="Comprehensive Zone Nova tier lists for PvE, PvP, Rifts, and Guild Raids. Find the best characters and team compositions for every game mode."
>
  <div class="tier-list-container">
    <!-- Mode Toggle -->
    <div class="mode-toggle">
      <button class="mode-btn active" id="view-mode-btn"> View Tier Lists </button>
      <button class="mode-btn" id="maker-mode-btn"> Create Your Own </button>
    </div>

    <!-- View Mode Content -->
    <div id="view-mode-content">
      <!-- Tier List Type Selector -->
      <div class="tier-list-selector">
        <button class="tier-type-btn active" data-list-type="pve"> Overall PvE </button>
        <button class="tier-type-btn" data-list-type="pvp"> PvP Arena </button>
        <button class="tier-type-btn" data-list-type="rift"> Space-Time Rifts </button>
        <button class="tier-type-btn" data-list-type="guild-raid"> Guild Raid </button>
        <button class="tier-type-btn" data-list-type="new-player"> New Player / F2P </button>
      </div>
    </div>

    <!-- Maker Mode Content -->
    <div id="maker-mode-content" style="display: none;">
      <p class="maker-description" style="text-align: center; color: var(--zn-text-secondary); margin-bottom: 1rem;">
        Click a character to select, then click a tier to place it. Or drag and drop.
      </p>
      <div class="maker-controls">
        <button class="control-btn" id="reset-tier-list">Reset Tier List</button>
      </div>
    </div>

    <!-- Tier List Info -->
    <div class="tier-list-info" id="tier-list-info">
      <h2 class="tier-list-title" id="list-title">Overall PvE Tier List</h2>
      <p class="tier-list-description" id="list-description">
        Character rankings for general PvE content including story, events, and exploration.
      </p>
      <p class="tier-list-updated" id="list-updated">Last updated: 2025-09-19</p>
    </div>

    <!-- Maker Mode: Character Pool (Grid Layout) -->
    <div id="maker-pool" style="display: none;">
      <div class="maker-pool-grid">
        {ZONE_NOVA_CHARACTERS.map(char => (
          <div
            class="pool-character-card draggable"
            data-character={char.name}
            data-rarity={char.rarity}
            data-element={char.element}
            draggable="true"
          >
            <div class="pool-image-wrapper">
              <ZNCharacterImage
                imageName={char.image}
                alt={char.name}
                width={75}
                height={75}
                loading="lazy"
                quality={90}
                format="webp"
              />
            </div>
            <div class="pool-character-name">{char.name}</div>
            <div class="pool-character-badges">
              <span class={`pool-mini-badge rarity-${char.rarity.toLowerCase()}`}>
                {char.rarity}
              </span>
              {char.element && (
                <span class={`pool-mini-badge element-${char.element.toLowerCase()}`}>
                  {char.element}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Maker Mode: Tier List -->
    <div id="maker-tier-list" style="display: none;">
      {Object.entries(TIER_DEFINITIONS).map(([tier, definition]) => (
        <div class="tier-row">
          <div class={`tier-label tier-${getTierClassName(tier)}`}>{definition.label}</div>
          <div class="tier-characters droppable" data-tier={tier}>
            <div class="drop-zone-hint">Drop characters here</div>
          </div>
        </div>
      ))}
    </div>

    <!-- PvE Tier List Display (Visible by default) -->
    <div class="tier-list-display" id="pve-tier-display">
      {Object.entries(ALL_TIER_LISTS['pve'].tiers).map(([tier, characters]) => (
        <div class="tier-row" data-tier={tier}>
          <div class={`tier-label tier-${getTierClassName(tier)}`}>
            {TIER_DEFINITIONS[tier].label}
          </div>
          <div class="tier-characters">
            {characters.map(charInfo => {
              const charData = characterMap[charInfo.name];
              if (!charData) return null;

              return (
                <div
                  class="tier-character-card"
                  onclick={`window.location.href=${JSON.stringify(charData.detailUrl)}`}
                >
                  <div class="character-image-wrapper">
                    <ZNCharacterImage
                      imageName={charData.image}
                      alt={charData.name}
                      width={160}
                      height={160}
                      loading="lazy"
                      quality={100}
                      format="jpg"
                    />
                  </div>
                  <div class="character-name">{charData.name}</div>
                  <div class="character-badges">
                    <span class={`mini-badge rarity-${charData.rarity.toLowerCase()}`}>
                      {charData.rarity}
                    </span>
                    {charData.element && (
                      <span class={`mini-badge element-${charData.element.toLowerCase()}`}>
                        {charData.element}
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- PvP Tier List Display (Hidden by default) -->
    <div class="tier-list-display" id="pvp-tier-display" style="display: none;">
      {Object.entries(ALL_TIER_LISTS['pvp'].tiers).map(([tier, characters]) => (
        <div class="tier-row" data-tier={tier}>
          <div class={`tier-label tier-${getTierClassName(tier)}`}>
            {TIER_DEFINITIONS[tier].label}
          </div>
          <div class="tier-characters">
            {characters.map(charInfo => {
              const charData = characterMap[charInfo.name];
              if (!charData) return null;

              return (
                <div
                  class="tier-character-card"
                  onclick={`window.location.href=${JSON.stringify(charData.detailUrl)}`}
                >
                  <div class="character-image-wrapper">
                    <ZNCharacterImage
                      imageName={charData.image}
                      alt={charData.name}
                      width={160}
                      height={160}
                      loading="lazy"
                      quality={100}
                      format="jpg"
                    />
                  </div>
                  <div class="character-name">{charData.name}</div>
                  <div class="character-badges">
                    <span class={`mini-badge rarity-${charData.rarity.toLowerCase()}`}>
                      {charData.rarity}
                    </span>
                    {charData.element && (
                      <span class={`mini-badge element-${charData.element.toLowerCase()}`}>
                        {charData.element}
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- Rift Tier List Display (Hidden by default) -->
    <div class="tier-list-display" id="rift-tier-display" style="display: none;">
      {Object.entries(ALL_TIER_LISTS['rift'].tiers).map(([tier, characters]) => (
        <div class="tier-row" data-tier={tier}>
          <div class={`tier-label tier-${getTierClassName(tier)}`}>
            {TIER_DEFINITIONS[tier].label}
          </div>
          <div class="tier-characters">
            {characters.map(charInfo => {
              const charData = characterMap[charInfo.name];
              if (!charData) return null;

              return (
                <div
                  class="tier-character-card"
                  onclick={`window.location.href=${JSON.stringify(charData.detailUrl)}`}
                >
                  <div class="character-image-wrapper">
                    <ZNCharacterImage
                      imageName={charData.image}
                      alt={charData.name}
                      width={160}
                      height={160}
                      loading="lazy"
                      quality={100}
                      format="jpg"
                    />
                  </div>
                  <div class="character-name">{charData.name}</div>
                  <div class="character-badges">
                    <span class={`mini-badge rarity-${charData.rarity.toLowerCase()}`}>
                      {charData.rarity}
                    </span>
                    {charData.element && (
                      <span class={`mini-badge element-${charData.element.toLowerCase()}`}>
                        {charData.element}
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- Guild Raid Tier List Display (Hidden by default) -->
    <div class="tier-list-display" id="guild-raid-tier-display" style="display: none;">
      {Object.entries(ALL_TIER_LISTS['guild-raid'].tiers).map(([tier, characters]) => (
        <div class="tier-row" data-tier={tier}>
          <div class={`tier-label tier-${getTierClassName(tier)}`}>
            {TIER_DEFINITIONS[tier].label}
          </div>
          <div class="tier-characters">
            {characters.map(charInfo => {
              const charData = characterMap[charInfo.name];
              if (!charData) return null;

              return (
                <div
                  class="tier-character-card"
                  onclick={`window.location.href=${JSON.stringify(charData.detailUrl)}`}
                >
                  <div class="character-image-wrapper">
                    <ZNCharacterImage
                      imageName={charData.image}
                      alt={charData.name}
                      width={160}
                      height={160}
                      loading="lazy"
                      quality={100}
                      format="jpg"
                    />
                  </div>
                  <div class="character-name">{charData.name}</div>
                  <div class="character-badges">
                    <span class={`mini-badge rarity-${charData.rarity.toLowerCase()}`}>
                      {charData.rarity}
                    </span>
                    {charData.element && (
                      <span class={`mini-badge element-${charData.element.toLowerCase()}`}>
                        {charData.element}
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- New Player Tier List Display (Hidden by default) -->
    <div class="tier-list-display" id="new-player-tier-display" style="display: none;">
      {Object.entries(ALL_TIER_LISTS['new-player'].tiers).map(([tier, characters]) => (
        <div class="tier-row" data-tier={tier}>
          <div class={`tier-label tier-${getTierClassName(tier)}`}>
            {TIER_DEFINITIONS[tier].label}
          </div>
          <div class="tier-characters">
            {characters.map(charInfo => {
              const charData = characterMap[charInfo.name];
              if (!charData) return null;

              return (
                <div
                  class="tier-character-card"
                  onclick={`window.location.href=${JSON.stringify(charData.detailUrl)}`}
                >
                  <div class="character-image-wrapper">
                    <ZNCharacterImage
                      imageName={charData.image}
                      alt={charData.name}
                      width={160}
                      height={160}
                      loading="lazy"
                      quality={100}
                      format="jpg"
                    />
                  </div>
                  <div class="character-name">{charData.name}</div>
                  <div class="character-badges">
                    <span class={`mini-badge rarity-${charData.rarity.toLowerCase()}`}>
                      {charData.rarity}
                    </span>
                    {charData.element && (
                      <span class={`mini-badge element-${charData.element.toLowerCase()}`}>
                        {charData.element}
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- Tier Legend -->
    <div class="tier-legend" id="tier-legend">
      {Object.entries(TIER_DEFINITIONS).map(([tier, definition]) => (
        <div class="legend-item">
          <div class={`legend-tier tier-${getTierClassName(tier)}`}>{definition.label}</div>
          <div class="legend-description">
            <span class="legend-label">{definition.label} Tier</span>
            <span class="legend-text">{definition.description}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Quick Links -->
    <div
      style="display: flex; gap: 1rem; justify-content: center; margin: 2rem 0; flex-wrap: wrap;"
    >
      <a
        href="/guides/zone-nova/characters/"
        style="display: inline-block; padding: 0.75rem 1.5rem; background: linear-gradient(135deg, var(--amber-glow), #FF9800); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; transition: all 0.3s ease;"
      >
        Character Database
      </a>
      <a
        href="/guides/zone-nova/team-synergy"
        style="display: inline-block; padding: 0.75rem 1.5rem; background: linear-gradient(135deg, #64b5f6, #42a5f5); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; transition: all 0.3s ease;"
      >
        Team Synergy
      </a>
      <a
        href="/guides/zone-nova/character-rankings"
        style="display: inline-block; padding: 0.75rem 1.5rem; background: linear-gradient(135deg, #66bb6a, #4caf50); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; transition: all 0.3s ease;"
      >
        Stat Rankings
      </a>
    </div>
  </div>

  <!-- Tier List Maker Script -->
  <script define:vars={{ characterMap, ALL_TIER_LISTS }}>
    document.addEventListener('DOMContentLoaded', () => {
      // View mode elements
      const listTitle = document.getElementById('list-title');
      const listDescription = document.getElementById('list-description');
      const listUpdated = document.getElementById('list-updated');
      const typeButtons = document.querySelectorAll('.tier-type-btn');
      const viewModeBtn = document.getElementById('view-mode-btn');
      const makerModeBtn = document.getElementById('maker-mode-btn');
      const viewModeContent = document.getElementById('view-mode-content');
      const makerModeContent = document.getElementById('maker-mode-content');
      const tierListInfo = document.getElementById('tier-list-info');
      const tierLegend = document.getElementById('tier-legend');
      const tierListDisplays = document.querySelectorAll('.tier-list-display[id$="-tier-display"]');

      // Maker mode elements
      const makerPool = document.getElementById('maker-pool');
      const makerTierList = document.getElementById('maker-tier-list');
      const resetBtn = document.getElementById('reset-tier-list');

      let currentListType = 'pve';
      let currentMode = 'view';
      let selectedCharacter = null;
      const tierAssignments = {};
      const STORAGE_KEY = 'zn-custom-tier-list';
      let makerInitialized = false;

      // Update tier list info
      function updateTierListInfo(listType) {
        const tierList = ALL_TIER_LISTS[listType];
        if (!tierList) return;
        if (listTitle) listTitle.textContent = tierList.name;
        if (listDescription) listDescription.textContent = tierList.description;
        if (listUpdated) listUpdated.textContent = `Last updated: ${tierList.lastUpdated}`;

        tierListDisplays.forEach(display => {
          display.style.display = display.id === `${listType}-tier-display` ? 'block' : 'none';
        });
      }

      // Type button listeners
      typeButtons.forEach(button => {
        button.addEventListener('click', () => {
          const listType = button.dataset.listType;
          if (!listType || listType === currentListType) return;
          typeButtons.forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');
          currentListType = listType;
          updateTierListInfo(listType);
        });
      });

      // View mode button
      viewModeBtn.addEventListener('click', () => {
        currentMode = 'view';
        viewModeBtn.classList.add('active');
        makerModeBtn.classList.remove('active');
        viewModeContent.style.display = 'block';
        makerModeContent.style.display = 'none';
        tierListInfo.style.display = 'block';
        if (tierLegend) tierLegend.style.display = 'grid';
        if (makerPool) makerPool.style.display = 'none';
        if (makerTierList) makerTierList.style.display = 'none';
        updateTierListInfo(currentListType);
      });

      // Maker mode button
      makerModeBtn.addEventListener('click', () => {
        currentMode = 'maker';
        makerModeBtn.classList.add('active');
        viewModeBtn.classList.remove('active');
        viewModeContent.style.display = 'none';
        makerModeContent.style.display = 'block';
        tierListInfo.style.display = 'none';
        if (tierLegend) tierLegend.style.display = 'none';
        if (makerPool) makerPool.style.display = 'block';
        if (makerTierList) makerTierList.style.display = 'flex';
        tierListDisplays.forEach(d => d.style.display = 'none');
        if (!makerInitialized) {
          initializeMaker();
          makerInitialized = true;
        }
      });

      // Initialize maker mode
      function initializeMaker() {
        setupPoolCards();
        setupDropZones();
        loadFromStorage();
      }

      // Setup pool card drag events
      function setupPoolCards() {
        document.querySelectorAll('#maker-pool .pool-character-card').forEach(card => {
          const characterName = card.dataset.character;

          card.addEventListener('dragstart', e => {
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('character', characterName);
            e.dataTransfer.setData('source', 'pool');
            card.classList.add('dragging');
          });

          card.addEventListener('dragend', () => {
            card.classList.remove('dragging');
          });

          // Click to select (works on all devices now)
          card.addEventListener('click', () => {
            // If clicking same card, deselect
            if (selectedCharacter === characterName) {
              card.classList.remove('selected');
              selectedCharacter = null;
              document.querySelectorAll('.tier-characters.droppable').forEach(z => z.classList.remove('awaiting-placement'));
              return;
            }

            // Select this card
            document.querySelectorAll('.pool-character-card').forEach(c => c.classList.remove('selected'));
            document.querySelectorAll('.tier-character-card.in-tier').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            selectedCharacter = characterName;
            document.querySelectorAll('.tier-characters.droppable').forEach(z => z.classList.add('awaiting-placement'));
          });
        });
      }

      // Setup drop zones
      function setupDropZones() {
        document.querySelectorAll('.tier-characters.droppable').forEach(zone => {
          const tierName = zone.dataset.tier;

          zone.addEventListener('dragover', e => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            zone.classList.add('drag-over');
          });

          zone.addEventListener('dragleave', () => {
            zone.classList.remove('drag-over');
          });

          zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            const characterName = e.dataTransfer.getData('character');
            const source = e.dataTransfer.getData('source');

            if (characterName) {
              if (source === 'tier' && tierAssignments[characterName]) {
                moveCardBetweenTiers(characterName, tierName);
              } else {
                moveCardToTier(characterName, tierName);
              }
            }
          });

          // Click to place (works on all devices now)
          zone.addEventListener('click', () => {
            if (!selectedCharacter) return;
            moveCardToTier(selectedCharacter, tierName);
            document.querySelectorAll('.pool-character-card').forEach(c => c.classList.remove('selected'));
            document.querySelectorAll('.tier-character-card.in-tier').forEach(c => c.classList.remove('selected'));
            document.querySelectorAll('.tier-characters').forEach(z => z.classList.remove('awaiting-placement'));
            selectedCharacter = null;
          });
        });
      }

      // Move card to tier
      function moveCardToTier(characterName, tierName) {
        const poolCard = document.querySelector(`#maker-pool [data-character="${characterName}"]`);
        const targetZone = document.querySelector(`#maker-tier-list [data-tier="${tierName}"]`);

        if (!poolCard || !targetZone) return;

        // Hide pool card
        poolCard.style.display = 'none';

        // Create tier card
        const charData = characterMap[characterName];
        const tierCard = document.createElement('div');
        tierCard.className = 'tier-character-card draggable in-tier';
        tierCard.dataset.character = characterName;
        tierCard.draggable = true;

        const elementClass = charData?.element ? charData.element.toLowerCase() : '';
        const elementName = charData?.element
          ? charData.element.charAt(0).toUpperCase() + charData.element.slice(1).toLowerCase()
          : '';

        tierCard.innerHTML = `
          <div class="character-image-wrapper">
            <img src="${poolCard.querySelector('img').src}" alt="${characterName}" loading="lazy" />
          </div>
          <div class="character-name">${characterName}</div>
          <div class="character-badges">
            <span class="mini-badge rarity-${charData?.rarity?.toLowerCase() || 'sr'}">${charData?.rarity || 'SR'}</span>
            ${charData?.element ? `<span class="mini-badge element-${elementClass}">${elementName}</span>` : ''}
          </div>
          <button class="remove-btn" title="Remove from tier">×</button>
        `;

        // Setup tier card events
        setupTierCardEvents(tierCard, characterName);

        // Hide hint
        const hint = targetZone.querySelector('.drop-zone-hint');
        if (hint) hint.style.display = 'none';

        targetZone.appendChild(tierCard);
        tierAssignments[characterName] = tierName;
        saveToStorage();
      }

      // Setup tier card events
      function setupTierCardEvents(card, characterName) {
        card.addEventListener('dragstart', e => {
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('character', characterName);
          e.dataTransfer.setData('source', 'tier');
          card.classList.add('dragging');
        });

        card.addEventListener('dragend', () => {
          card.classList.remove('dragging');
        });

        card.querySelector('.remove-btn').addEventListener('click', e => {
          e.stopPropagation();
          returnCardToPool(characterName);
        });
      }

      // Move card between tiers
      function moveCardBetweenTiers(characterName, newTierName) {
        const tierCard = document.querySelector(`#maker-tier-list .in-tier[data-character="${characterName}"]`);
        const targetZone = document.querySelector(`#maker-tier-list [data-tier="${newTierName}"]`);

        if (!tierCard || !targetZone) return;

        const oldZone = tierCard.parentElement;
        tierCard.remove();
        targetZone.appendChild(tierCard);
        tierAssignments[characterName] = newTierName;

        // Show hint if old tier is empty
        if (oldZone && oldZone.querySelectorAll('.in-tier').length === 0) {
          const hint = oldZone.querySelector('.drop-zone-hint');
          if (hint) hint.style.display = 'block';
        }

        // Hide hint in new tier
        const hint = targetZone.querySelector('.drop-zone-hint');
        if (hint) hint.style.display = 'none';

        saveToStorage();
      }

      // Return card to pool
      function returnCardToPool(characterName) {
        const poolCard = document.querySelector(`#maker-pool [data-character="${characterName}"]`);
        const tierCard = document.querySelector(`#maker-tier-list .in-tier[data-character="${characterName}"]`);

        if (!poolCard || !tierCard) return;

        const oldZone = tierCard.parentElement;
        poolCard.style.display = '';
        tierCard.remove();
        delete tierAssignments[characterName];

        // Show hint if tier is empty
        if (oldZone && oldZone.querySelectorAll('.in-tier').length === 0) {
          const hint = oldZone.querySelector('.drop-zone-hint');
          if (hint) hint.style.display = 'block';
        }

        saveToStorage();
      }

      // Reset
      resetBtn?.addEventListener('click', () => {
        Object.keys(tierAssignments).forEach(returnCardToPool);
        localStorage.removeItem(STORAGE_KEY);
      });

      // Storage
      function saveToStorage() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(tierAssignments));
      }

      function loadFromStorage() {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (!stored) return;

        try {
          const data = JSON.parse(stored);
          Object.entries(data).forEach(([name, tier]) => {
            if (characterMap[name]) {
              moveCardToTier(name, tier);
            }
          });
        } catch (e) {
          console.error('Failed to load tier list:', e);
        }
      }

      // Initial
      updateTierListInfo('pve');
    });
  </script>
</TierListLayout>

<style>
  /* Maker Pool Grid - better layout than sidebar */
  .maker-pool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(85px, 1fr));
    gap: 0.75rem;
    padding: 1rem;
    background: var(--zn-bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--zn-border-primary);
    margin-bottom: 1.5rem;
  }

  #maker-tier-list {
    flex-direction: column;
    gap: 0.5rem;
  }

  #maker-tier-list .tier-row {
    display: flex;
    background: var(--zn-bg-primary);
    border-radius: 8px;
    border: 1px solid var(--zn-border-primary);
    min-height: 100px;
