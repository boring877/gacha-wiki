---
import RadiantMessengerLayout from '../../../../layouts/stella-sora/RadiantMessengerLayout.astro';
import { radiantMessengerHolyNightSpiritEvent } from '../../../../data/stella-sora/events/radiant-messenger-holy-night-spirit.js';
import RadiantMessengerImages from '../../../../components/stella-sora/shop-events/RadiantMessengerImages.astro';
import '../../../../styles/games/stella-sora/events/radiant-messenger.css';

const event = radiantMessengerHolyNightSpiritEvent;

// Set metadata
const title = `${event.title} - ${event.subtitle}`;
const description = event.description;

// Transform shop items
const shopItems = event.shopItems.map(item => ({
  name: item.name,
  stockLeft: item.stock?.type === 'unlimited' ? 0 : item.stock?.quantity || 1,
  cost: item.price || 0,
  quantity: item.quantity || 1,
  image: item.image,
  rarity: item.rarity?.toLowerCase() || 'common',
  stockType: item.stock?.type || 'limited',
}));

// Calculate total cost for all limited items
const totalCost = event.shopItems.reduce((sum, item) => {
  if (item.stock?.type === 'limited') {
    return sum + item.price * (item.stock?.quantity || 1);
  }
  return sum;
}, 0);

// Calculate total cookies from quests
const questCategories = Object.values(event.quests || {});
const totalCookiesFromQuests = questCategories.reduce((total, category) => {
  return (
    total + category.quests.reduce((catTotal, quest) => catTotal + (quest.cookieReward || 0), 0)
  );
}, 0);
---

<RadiantMessengerLayout
  title={title}
  description={description}
  gameTitle={event.title}
  endDate={event.shopEndDate}
  currency={event.currency}
>
  <!-- Limited Disc Notice -->
  <section class="limited-disc-notice">
    <div class="notice-content">
      <h2 class="notice-title">Limited Disc - Must Buy!</h2>
      <div class="notice-disc">
        <RadiantMessengerImages
          imageName="item_214041.png"
          alt="A Gift for the Journey"
          width={200}
          height={200}
        />
        <div class="notice-disc-info">
          <span class="disc-name">{event.limitedDisc.name}</span>
          <span class="disc-note">{event.limitedDisc.note}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Currency Info -->
  <section class="currency-section">
    <div class="currency-header">
      <RadiantMessengerImages
        imageName="item_73104.png"
        alt={event.currency.name}
        width={100}
        height={100}
      />
      <h3 class="currency-name">{event.currency.name}</h3>
    </div>
    <div class="currency-sources">
      <h4>How to Obtain:</h4>
      <ul>
        {event.currency.sources.map(source => <li>{source}</li>)}
      </ul>
    </div>
    <div class="total-cost-section">
      <span class="total-label">Total Cost (All Limited Items):</span>
      <div class="total-value">
        <RadiantMessengerImages
          imageName="item_73104.png"
          alt={event.currency.name}
          width={50}
          height={50}
        />
        <span class="total-amount">{totalCost.toLocaleString()}</span>
      </div>
    </div>
  </section>

  <!-- Shop Items -->
  <section class="ss-shop-event-items">
    <h2 class="ss-shop-items-title">Shop Items</h2>

    <div class="shop-items-grid">
      {
        shopItems.map(item => (
          <div class="shop-item-card" data-rarity={item.rarity}>
            <div class="item-image-wrapper">
              <RadiantMessengerImages
                imageName={item.image}
                alt={item.name}
                className="item-image"
                width={300}
                height={300}
              />
            </div>

            <div class="item-info">
              <h3 class="item-title">{item.name}</h3>

              <div class="item-stats">
                <div class="stat-row">
                  <span class="stat-label">Stock:</span>
                  <span class="stat-value stock-amount">
                    {item.stockType === 'unlimited' ? '∞' : item.stockLeft}
                  </span>
                </div>

                <div class="stat-row">
                  <span class="stat-label">Cost:</span>
                  <div class="cost-display">
                    <RadiantMessengerImages
                      imageName="item_73104.png"
                      alt={event.currency.name}
                      className="price-icon"
                      width={50}
                      height={50}
                    />
                    <span class="stat-value item-cost">{item.cost}</span>
                  </div>
                </div>

                <div class="stat-row">
                  <span class="stat-label">Qty:</span>
                  <span class="stat-value">x{item.quantity}</span>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Quest Rewards Section -->
  {
    event.quests && (
      <section class="quest-rewards-section">
        <h2 class="ss-shop-items-title">Quest Rewards</h2>

        <div class="quest-summary">
          <span class="quest-summary-label">Total Cookies from All Quests:</span>
          <div class="quest-summary-value">
            <RadiantMessengerImages
              imageName="item_73104.png"
              alt={event.currency.name}
              width={50}
              height={50}
            />
            <span class="quest-summary-amount">{totalCookiesFromQuests.toLocaleString()}</span>
          </div>
        </div>

        {Object.values(event.quests).map(category => (
          <div class="quest-category">
            <h3 class="quest-category-title">{category.title}</h3>

            {category.completionRewards && (
              <div class="quest-completion-rewards">
                <p class="quest-completion-label">After finishing all quests you get:</p>
                <p class="quest-rewards-text">{category.completionRewards.items.join(', ')}</p>
              </div>
            )}

            <div class="quest-table-container">
              <table class="quest-table">
                <thead>
                  <tr>
                    <th>Quest Name</th>
                    <th>{event.currency.name}</th>
                  </tr>
                </thead>
                <tbody>
                  {category.quests.map(quest => (
                    <tr>
                      <td>{quest.name}</td>
                      <td>x{quest.cookieReward}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="quest-category-total">
              <span>Category Total:</span>
              <strong>
                x{category.quests.reduce((sum, q) => sum + q.cookieReward, 0).toLocaleString()}
              </strong>
            </div>
          </div>
        ))}
      </section>
    )
  }
</RadiantMessengerLayout>
