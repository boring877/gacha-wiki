---
import StarSaviorLayout from '../../layouts/star-savior/LandingLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { starSaviorConfig } from '../../data/star-savior/star-savior.js';
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/games/star-savior/hero.png';

const { meta, gameInfo, categoryGroups } = starSaviorConfig;
---

<StarSaviorLayout
  title={meta.title}
  description={meta.description}
  gameTitle={meta.gameTitle}
  heroImage={heroImg}
>
  <section class="content-section">
    <div class="game-description">
      <p>{gameInfo.description}</p>
    </div>

    <p class="last-updated">
      Last Updated: <FormattedDate date={gameInfo.lastUpdated} />
    </p>
  </section>

  <section class="ss-resources-section">
    <h2 class="ss-resources-title">Guides & Resources</h2>

    <div class="ss-resources-grid">
      {
        categoryGroups.map(category => (
          <div class={`ss-resource-category ss-category-${category.size}`}>
            <div class="ss-category-header">
              <h3>{category.title}</h3>
              <p class="ss-category-description">{category.description}</p>
            </div>
            <div class="ss-buttons-grid">
              {category.guides.map(guide => (
                <a
                  href={guide.url}
                  class="ss-resource-button"
                  aria-label={`Navigate to ${guide.title}`}
                >
                  {guide.title}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</StarSaviorLayout>
