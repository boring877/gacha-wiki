---
// Star Savior Gear/Equipment Database Page
// Set-centric card layout: 3 sets as hero cards with their specific set bonuses
import LandingLayout from '../../../../layouts/star-savior/LandingLayout.astro';
import { STAR_SAVIOR_GEAR, STAR_SAVIOR_SET_BONUSES, EQUIP_SET_BONUS_MAP } from '../../../../data/star-savior/gear.js';

import '../../../../styles/games/star-savior/ss-gear-database.css';
import SSEquipImage from '../../../../components/star-savior/SSEquipImage.astro';
import SSEquipSlotImage from '../../../../components/star-savior/SSEquipSlotImage.astro';
import SSStatIcon from '../../../../components/star-savior/SSStatIcon.astro';
import SSEquipSetImage from '../../../../components/star-savior/SSEquipSetImage.astro';

const STAT_DISPLAY_MAP: Record<string, string> = {
  ATK: 'ATK',
  DEF: 'DEF',
  'Flat HP': 'HP',
  SPD: 'SPD',
  'CRIT Rate': 'CRIT Rate',
  'CRIT Damage': 'CRIT DMG',
  'Effect Hit': 'Effect Hit',
  Evasion: 'Effect RES',
  'ATK %': 'ATK %',
  'DEF %': 'DEF %',
  'HP %': 'HP %',
};

const SLOT_ORDER = ['Weapon', 'Gloves', 'Armor', 'Boots', 'Necklace', 'Ring'];

const GRADE_ORDER: Record<string, number> = { Uncommon: 0, Rare: 1, Unique: 2, Legendary: 3 };

const setNames = [...new Set(STAR_SAVIOR_GEAR.map(g => g.set))].sort();

const setsData = setNames.map(setName => {
  const items = STAR_SAVIOR_GEAR.filter(g => g.set === setName);
  const types = SLOT_ORDER.map(type => {
    const typeItems = items.filter(g => g.type === type).sort((a, b) => {
      if (a.tier !== b.tier) return a.tier - b.tier;
      return GRADE_ORDER[a.grade] - GRADE_ORDER[b.grade];
    });
    return { type, items: typeItems };
  }).filter(t => t.items.length > 0);

  const representativeItem = items.find(g => g.type === 'Weapon' && g.tier === 1 && g.grade === 'Uncommon') || items[0];
  const totalItems = items.length;
  const bonusIds = EQUIP_SET_BONUS_MAP[setName] || [];
  const bonuses = bonusIds.map(id => STAR_SAVIOR_SET_BONUSES.find(sb => sb.id === id)).filter(Boolean);

  return {
    name: setName,
    desc: representativeItem?.desc || '',
    types,
    totalItems,
    bonuses,
  };
});
---

<LandingLayout title="Equipment Database - Star Savior" description="Complete equipment database for Star Savior. Browse 3 sets, 6 types, and set bonuses." gameTitle="Equipment Database">
  <section class="ss-gear-overview">
    <div class="ss-gear-stats-row">
      <div class="ss-gear-stat-pill"><span class="ss-gear-stat-num">{STAR_SAVIOR_GEAR.length}</span> Items</div>
      <div class="ss-gear-stat-pill"><span class="ss-gear-stat-num">{setNames.length}</span> Sets</div>
      <div class="ss-gear-stat-pill"><span class="ss-gear-stat-num">{SLOT_ORDER.length}</span> Types</div>
      <div class="ss-gear-stat-pill"><span class="ss-gear-stat-num">{STAR_SAVIOR_SET_BONUSES.length}</span> Set Bonuses</div>
    </div>
  </section>

  <section class="ss-gear-sets-section">
    <h2 class="ss-gear-section-title">Equipment Sets</h2>
    <div class="ss-gear-set-list">
      {setsData.map((setData, setIdx) => (
        <div class="ss-gear-set-card" data-set-idx={setIdx}>
          <div class="ss-gear-set-hero" onclick={`this.parentElement.classList.toggle('ss-gear-set-card--open')`}>
            <div class="ss-gear-set-hero-icon">
              {setData.types[0]?.items[0] && (
                <SSEquipImage icon={setData.types[0].items[0].icon} alt={setData.name} width={80} />
              )}
            </div>
            <div class="ss-gear-set-hero-info">
              <h3 class="ss-gear-set-hero-name">{setData.name} Set</h3>
              <p class="ss-gear-set-hero-desc">{setData.desc}</p>
              <div class="ss-gear-set-hero-meta">
                <span>{setData.types.length} types</span>
                <span class="ss-gear-set-hero-sep">/</span>
                <span>{setData.totalItems} items</span>
                <span class="ss-gear-set-hero-sep">/</span>
                <span>{setData.bonuses.length} bonuses</span>
              </div>
            </div>
            <div class="ss-gear-set-hero-toggle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </div>
          </div>

          <div class="ss-gear-set-body">
            <div class="ss-gear-set-bonuses-row">
              <h4 class="ss-gear-set-bonuses-title">Set Bonuses</h4>
              <div class="ss-gear-set-bonuses-list">
                {setData.bonuses.map(sb => (
                  <div class="ss-gear-set-bonus-card">
                    <div class="ss-gear-set-bonus-header">
                      <SSEquipSetImage icon={sb.icon} size={28} />
                      <div class="ss-gear-set-bonus-info">
                        <div class="ss-gear-set-bonus-name">{sb.name}</div>
                        <div class="ss-gear-set-bonus-pieces">{sb.needParts} pieces</div>
                      </div>
                    </div>
                    <div class="ss-gear-set-bonus-stats">{sb.statsDisplay}</div>
                  </div>
                ))}
              </div>
            </div>

            {setData.types.map(typeData => (
              <div class="ss-gear-type-group">
                <div class="ss-gear-type-header">
                  <SSEquipSlotImage slot={typeData.type} size={20} />
                  <h4 class="ss-gear-type-name">{typeData.type}</h4>
                </div>
                <div class="ss-gear-type-items">
                  {typeData.items.map(item => (
                    <a
                      href={`/guides/star-savior/gear/${item.slug}/`}
                      class="ss-gear-item-card"
                    >
                      <SSEquipImage icon={item.icon} alt={item.name} width={48} />
                      <div class="ss-gear-item-info">
                        <div class="ss-gear-item-name">{item.name}</div>
                        <div class="ss-gear-item-meta">
                          <span class={`ss-grade-badge ss-grade-${item.grade.toLowerCase()}`}>{item.grade}</span>
                          <span class="ss-gear-item-tier">T{item.tier}</span>
                          <div class="ss-gear-item-stat">
                            <SSStatIcon stat={STAT_DISPLAY_MAP[item.mainStat] || item.mainStat} size={14} />
                            <span>{item.mainStatDisplay}</span>
                          </div>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</LandingLayout>
