---
// Star Savior Individual Equipment Detail Page
// Shows equip info, main stat scaling, substats, and set bonuses
import LandingLayout from '../../../../layouts/star-savior/LandingLayout.astro';
import { STAR_SAVIOR_GEAR, STAR_SAVIOR_SET_BONUSES, EQUIP_SET_BONUS_MAP } from '../../../../data/star-savior/gear.js';

import '../../../../styles/games/star-savior/ss-gear-detail.css';
import SSEquipImage from '../../../../components/star-savior/SSEquipImage.astro';
import SSEquipSlotImage from '../../../../components/star-savior/SSEquipSlotImage.astro';
import SSEquipSetImage from '../../../../components/star-savior/SSEquipSetImage.astro';
import SSStatIcon from '../../../../components/star-savior/SSStatIcon.astro';

export function getStaticPaths() {
  return STAR_SAVIOR_GEAR.map((g) => ({
    params: { slug: g.slug },
  }));
}

const { slug } = Astro.params;

const gear = STAR_SAVIOR_GEAR.find(g => g.slug === slug);

if (!gear) {
  return Astro.redirect('/guides/star-savior/gear/');
}

const STAT_DISPLAY_MAP: Record<string, string> = {
  ATK: 'ATK',
  DEF: 'DEF',
  'Flat HP': 'HP',
  SPD: 'SPD',
  'CRIT Rate': 'CRIT Rate',
  'CRIT Damage': 'CRIT DMG',
  'Effect Hit': 'Effect Hit',
  Evasion: 'Effect RES',
  'ATK %': 'ATK %',
  'DEF %': 'DEF %',
  'HP %': 'HP %',
};

const maxLvl = gear.maxEnchantLevel;
const maxBonus = gear.enchantPerStat * maxLvl;
const isPercent = gear.mainStatDisplay.includes('%');
const totalMax = gear.mainStatValue + maxBonus;

const relevantBonusIds = EQUIP_SET_BONUS_MAP[gear.set] || [];
const relevantBonuses = relevantBonusIds.map(id => STAR_SAVIOR_SET_BONUSES.find(sb => sb.id === id)).filter(Boolean);

const substatTypes = [
  { stat: 'ATK', label: 'ATK' },
  { stat: 'HP', label: 'Flat HP' },
  { stat: 'DEF', label: 'DEF' },
  { stat: 'SPD', label: 'SPD' },
  { stat: 'ATK %', label: 'ATK %' },
  { stat: 'HP %', label: 'HP %' },
  { stat: 'DEF %', label: 'DEF %' },
  { stat: 'CRIT Rate', label: 'CRIT Rate' },
  { stat: 'CRIT DMG', label: 'CRIT Damage' },
  { stat: 'Effect Hit', label: 'Effect Hit' },
  { stat: 'Effect RES', label: 'Evasion' },
];
---

<LandingLayout title={gear.name} description={`${gear.name} - ${gear.grade} ${gear.type} from the ${gear.set} set in Star Savior.`} gameTitle={gear.name}>
  <div class="ss-gd-card">
    <div class="ss-gd-card-icon">
      <SSEquipImage icon={gear.icon} alt={gear.name} width={120} />
    </div>
    <div class="ss-gd-card-body">
      <h2 class="ss-gd-card-name">{gear.name}</h2>
      <div class="ss-gd-card-badges">
        <span class={`ss-grade-badge ss-grade-${gear.grade.toLowerCase()}`}>{gear.grade}</span>
        <span class="ss-gd-card-badge">{gear.set} Set</span>
        <span class="ss-gd-card-badge ss-gd-card-badge--dim">Tier {gear.tier}</span>
        <span class="ss-gd-card-badge ss-gd-card-badge--dim">
          <SSEquipSlotImage slot={gear.type} size={14} />
          {gear.type}
        </span>
      </div>
      <div class="ss-gd-card-stat">
        <SSStatIcon stat={STAT_DISPLAY_MAP[gear.mainStat] || gear.mainStat} size={20} />
        <span class="ss-gd-card-stat-label">{gear.mainStat}</span>
        <span class="ss-gd-card-stat-value">{gear.mainStatDisplay}</span>
        <span class="ss-gd-card-stat-arrow">--></span>
        <span class="ss-gd-card-stat-max">{totalMax}{isPercent ? '%' : ''}</span>
        <span class="ss-gd-card-stat-note">(+{maxLvl})</span>
      </div>
      <div class="ss-gd-card-meta">
        <span>+{gear.enchantPerStat} per level</span>
        <span class="ss-gd-card-meta-sep">/</span>
        <span>Max +{maxLvl}</span>
      </div>
    </div>
  </div>

  {gear.desc && (
    <p class="ss-gd-desc">{gear.desc}</p>
  )}

  <section class="ss-gd-section">
    <h3 class="ss-gd-section-title">Enhancement</h3>
    <div class="ss-gd-enhance-grid">
      <div class="ss-gd-enhance-levels">
        <div class="ss-gd-enhance-levels-header">
          <span>Level</span>
          <span>Bonus</span>
          <span>Total</span>
        </div>
        {[0, 1, 3, 5, 7, 9, 10, 12, 15].map(lvl => (
          <div class={`ss-gd-enhance-levels-row ${lvl === maxLvl ? 'ss-gd-enhance-levels-row--max' : ''}`}>
            <span>+{lvl}</span>
            <span>+{gear.enchantPerStat * lvl}</span>
            <span>{gear.mainStatValue + gear.enchantPerStat * lvl}{isPercent ? '%' : ''}</span>
          </div>
        ))}
      </div>
      <div class="ss-gd-enhance-info">
        <div class="ss-gd-enhance-info-item">
          <div class="ss-gd-enhance-info-label">Per Level</div>
          <div class="ss-gd-enhance-info-value">+{gear.enchantPerStat}{isPercent ? '%' : ''}</div>
        </div>
        <div class="ss-gd-enhance-info-item">
          <div class="ss-gd-enhance-info-label">Max Level</div>
          <div class="ss-gd-enhance-info-value">{maxLvl}</div>
        </div>
        <div class="ss-gd-enhance-info-item">
          <div class="ss-gd-enhance-info-label">Total Bonus</div>
          <div class="ss-gd-enhance-info-value ss-gd-enhance-info-value--accent">+{maxBonus}{isPercent ? '%' : ''}</div>
        </div>
        <div class="ss-gd-enhance-info-item ss-gd-enhance-info-item--sub">
          <div class="ss-gd-enhance-info-label">New substat every</div>
          <div class="ss-gd-enhance-info-value">3 levels</div>
        </div>
      </div>
    </div>
  </section>

  <section class="ss-gd-section">
    <h3 class="ss-gd-section-title">Available Substats</h3>
    <p class="ss-gd-section-desc">Each equipment can have up to <strong>4 substats</strong> rolled from the pool below. Higher grades start with more substats. Once all slots are filled, further enhancement upgrades existing substats instead.</p>
    <div class="ss-gd-substat-list">
      {substatTypes.map(s => (
        <div class="ss-gd-substat-item">
          <SSStatIcon stat={s.stat} size={18} />
          <span class="ss-gd-substat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="ss-gd-section">
    <h3 class="ss-gd-section-title">{gear.set} Set Bonuses</h3>
    <p class="ss-gd-section-desc">Only {gear.set} equipment can activate these bonuses.</p>
    <div class="ss-gd-bonuses-grid">
      {relevantBonuses.map(sb => (
        <div class="ss-gd-bonus-card">
          <div class="ss-gd-bonus-header">
            <SSEquipSetImage icon={sb.icon} size={24} />
            <div class="ss-gd-bonus-info">
              <div class="ss-gd-bonus-name">{sb.name}</div>
              <div class="ss-gd-bonus-pieces">{sb.needParts} pieces</div>
            </div>
          </div>
          <div class="ss-gd-bonus-stats">{sb.statsDisplay}</div>
        </div>
      ))}
    </div>
  </section>
</LandingLayout>
