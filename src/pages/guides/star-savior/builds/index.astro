---
// Star Savior Character Builds Database Page
// Card grid of all characters with build type, set, and substat preview
import LandingLayout from '../../../../layouts/star-savior/LandingLayout.astro';
import { CHARACTER_BUILDS, BUILD_TYPES } from '../../../../data/star-savior/builds.js';

import '../../../../styles/games/star-savior/ss-builds.css';
import SSCharacterImage from '../../../../components/star-savior/SSCharacterImage.astro';
import SSRarityImage from '../../../../components/star-savior/SSRarityImage.astro';
import SSRoleImage from '../../../../components/star-savior/SSRoleImage.astro';

const roles = [...new Set(CHARACTER_BUILDS.map(c => c.role))].sort();
const buildTypes = [...new Set(CHARACTER_BUILDS.map(c => c.buildType))];

const sorted = [...CHARACTER_BUILDS].sort((a, b) => {
  if (a.buildType !== b.buildType) return a.buildType === 'dps' ? -1 : 1;
  if (a.rarity !== b.rarity) return a.rarity === 'SSR' ? -1 : 1;
  return a.name.localeCompare(b.name);
});
---

<LandingLayout title="Character Builds - Star Savior" description="Equipment build recommendations for all Star Savior characters. DPS and Tank/Support builds with substat priorities." gameTitle="Character Builds">
  <section class="ss-builds-stats">
    <div class="ss-builds-stats-item">
      <div class="ss-builds-stats-value">{CHARACTER_BUILDS.length}</div>
      <div class="ss-builds-stats-label">Builds</div>
    </div>
    <div class="ss-builds-stats-divider"></div>
    <div class="ss-builds-stats-item">
      <div class="ss-builds-stats-value">{sorted.filter(c => c.buildType === 'dps').length}</div>
      <div class="ss-builds-stats-label">DPS</div>
    </div>
    <div class="ss-builds-stats-divider"></div>
    <div class="ss-builds-stats-item">
      <div class="ss-builds-stats-value">{sorted.filter(c => c.buildType === 'tank').length}</div>
      <div class="ss-builds-stats-label">Tank/Support</div>
    </div>
  </section>

  <div class="ss-builds-filter-section">
    <div class="ss-builds-filter-row">
      <div class="ss-builds-filter-group">
        <label class="ss-builds-filter-label">Search</label>
        <input type="text" id="build-search" class="ss-builds-filter-input" placeholder="Search by name..." />
      </div>
      <div class="ss-builds-filter-group">
        <label class="ss-builds-filter-label">Role</label>
        <select id="filter-role" class="ss-builds-filter-input">
          <option value="">All Roles</option>
          {roles.map(r => <option value={r}>{r}</option>)}
        </select>
      </div>
      <div class="ss-builds-filter-group">
        <label class="ss-builds-filter-label">Build</label>
        <select id="filter-build" class="ss-builds-filter-input">
          <option value="">All Builds</option>
          <option value="dps">DPS</option>
          <option value="tank">Tank / Support</option>
        </select>
      </div>
      <div class="ss-builds-filter-group">
        <label class="ss-builds-filter-label">Rarity</label>
        <select id="filter-rarity" class="ss-builds-filter-input">
          <option value="">All</option>
          <option value="SSR">SSR</option>
          <option value="SR">SR</option>
        </select>
      </div>
    </div>
  </div>

  <div class="ss-builds-grid" id="builds-grid">
    {sorted.map(char => (
      <a
        href={`/guides/star-savior/builds/${char.slug}/`}
        class="ss-builds-card build-card"
        data-name={char.name.toLowerCase()}
        data-role={char.role}
        data-build={char.buildType}
        data-rarity={char.rarity}
      >
        <div class="ss-builds-card-image">
          <SSCharacterImage slug={char.slug} alt={char.name} imageType="icon" width={160} height={160} />
        </div>
        <div class="ss-builds-card-body">
          <div class="ss-builds-card-name">{char.name}</div>
          <div class="ss-builds-card-badges">
            <SSRarityImage rarity={char.rarity} width={48} height={24} />
            <div class="ss-builds-card-role">
              <SSRoleImage role={char.role} width={20} height={20} />
              <span>{char.role}</span>
            </div>
          </div>
          <div class="ss-builds-card-meta">
            <span class={`ss-builds-card-type ss-builds-card-type--${char.buildType}`}>{char.buildType === 'dps' ? 'DPS' : 'Tank / Support'}</span>
            <span class="ss-builds-card-set">{char.set} Set</span>
          </div>
          <div class="ss-builds-card-subs">
            {char.substatPriority.slice(0, 3).map((s, i) => (
              <span class="ss-builds-card-sub">
                <span class="ss-builds-card-sub-rank">{i + 1}</span> {s}
              </span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="ss-builds-no-results" id="no-results">
    <div>No builds found</div>
    <div style="font-size:0.875rem;opacity:0.7;margin-top:0.25rem">Try adjusting your filters</div>
  </div>
</LandingLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const searchInput = document.getElementById('build-search');
  const roleFilter = document.getElementById('filter-role');
  const buildFilter = document.getElementById('filter-build');
  const rarityFilter = document.getElementById('filter-rarity');
  const noResults = document.getElementById('no-results');
  const cards = document.querySelectorAll('.build-card');

  function applyFilters() {
    const search = searchInput.value.toLowerCase();
    const role = roleFilter.value;
    const build = buildFilter.value;
    const rarity = rarityFilter.value;
    let visible = 0;

    cards.forEach(card => {
      const match = (!search || (card.dataset.name || '').includes(search))
        && (!role || card.dataset.role === role)
        && (!build || card.dataset.build === build)
        && (!rarity || card.dataset.rarity === rarity);
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  searchInput.addEventListener('input', applyFilters);
  roleFilter.addEventListener('change', applyFilters);
  buildFilter.addEventListener('change', applyFilters);
  rarityFilter.addEventListener('change', applyFilters);
});
</script>
