---
// Star Savior Individual Character Build Detail Page
// Full build breakdown: portrait, build type, set, 6 equipment slots with images, substats
import LandingLayout from '../../../../layouts/star-savior/LandingLayout.astro';
import { CHARACTER_BUILDS, BUILD_TYPES, SLOT_ORDER } from '../../../../data/star-savior/builds.js';

import '../../../../styles/games/star-savior/ss-builds.css';
import SSCharacterImage from '../../../../components/star-savior/SSCharacterImage.astro';
import SSRarityImage from '../../../../components/star-savior/SSRarityImage.astro';
import SSRoleImage from '../../../../components/star-savior/SSRoleImage.astro';
import SSStatIcon from '../../../../components/star-savior/SSStatIcon.astro';
import SSEquipImage from '../../../../components/star-savior/SSEquipImage.astro';

export function getStaticPaths() {
  return CHARACTER_BUILDS.map(char => ({
    params: { slug: char.slug },
    props: { char },
  }));
}

const { char } = Astro.props;

const STAT_ICON_MAP: Record<string, string> = {
  'ATK %': 'ATK',
  'HP %': 'HP',
  'DEF %': 'DEF',
  'CRIT Rate': 'Crit Rate',
  'CRIT Damage': 'Crit DMG',
  'Effect Hit': 'Effect Hit',
  'Effect RES': 'Effect RES',
  SPD: 'SPD',
  ATK: 'ATK',
  DEF: 'DEF',
  'Flat HP': 'HP',
};

const build = BUILD_TYPES[char.buildType];
const buildLabel = char.buildType === 'dps' ? 'DPS Build' : 'Tank / Support Build';
---

<LandingLayout title={`${char.name} Build - Star Savior`} description={`Equipment build guide for ${char.name} (${char.role}). ${buildLabel} with ${char.set} set.`} gameTitle={`${char.name} Build`}>
  <section class="ss-build-detail-header">
    <div class="ss-build-detail-portrait">
      <SSCharacterImage slug={char.slug} alt={char.name} imageType="portrait" width={280} height={280} />
    </div>
    <div class="ss-build-detail-info">
      <h1 class="ss-build-detail-name">{char.name}</h1>
      <div class="ss-build-detail-badges">
        <SSRarityImage rarity={char.rarity} width={64} height={32} />
        <div class="ss-build-detail-role">
          <SSRoleImage role={char.role} width={24} height={24} />
          <span>{char.role}</span>
        </div>
      </div>
      <div class="ss-build-detail-type-badge ss-build-detail-type-badge--{char.buildType}">
        {buildLabel}
      </div>
      <div class="ss-build-detail-set">
        <span class="ss-build-detail-set-label">Recommended Set</span>
        <span class="ss-build-detail-set-name">{char.set} Set</span>
      </div>
    </div>
  </section>

  <section class="ss-build-detail-section">
    <h2 class="ss-build-detail-heading">Equipment</h2>
    <div class="ss-build-detail-slots">
      {SLOT_ORDER.map(slot => {
        const rec = char.slots[slot];
        if (!rec) return null;
        return (
          <div class="ss-build-detail-slot">
            <div class="ss-build-detail-slot-icon">
              <SSEquipImage icon={rec.icon} alt={rec.itemName} width={64} />
            </div>
            <div class="ss-build-detail-slot-info">
              <div class="ss-build-detail-slot-name">{rec.itemName}</div>
              <div class="ss-build-detail-slot-meta">
                <span class="ss-build-detail-slot-grade">T2 Legendary</span>
                {rec.mainStat && (
                  <div class="ss-build-detail-slot-main">
                    <SSStatIcon stat={STAT_ICON_MAP[rec.mainStat] || rec.mainStat} size={16} />
                    <span>{rec.mainStat}</span>
                  </div>
                )}
              </div>
              <div class="ss-build-detail-slot-subs">
                <span class="ss-build-detail-slot-subs-label">Best Substats:</span>
                <div class="ss-build-detail-slot-subs-list">
                  {char.substatPriority.map(stat => (
                    <span class="ss-build-detail-slot-sub-tag">{stat}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="ss-build-detail-section">
    <h2 class="ss-build-detail-heading">Substat Priority</h2>
    <div class="ss-build-detail-subs">
      {char.substatPriority.map((stat, i) => (
        <div class="ss-build-detail-sub-item">
          <span class="ss-build-detail-sub-rank">{i + 1}</span>
          <SSStatIcon stat={STAT_ICON_MAP[stat] || stat} size={20} />
          <span class="ss-build-detail-sub-name">{stat}</span>
        </div>
      ))}
    </div>
  </section>
</LandingLayout>
