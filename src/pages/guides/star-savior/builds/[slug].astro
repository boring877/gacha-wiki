---
// Star Savior Individual Character Build Detail Page
// Full build: portrait, build type, set, 6 equipment slots with images/stats, tiered substats
import LandingLayout from '../../../../layouts/star-savior/LandingLayout.astro';
import { CHARACTER_BUILDS, BUILD_TYPES, SLOT_ORDER } from '../../../../data/star-savior/builds.js';

import '../../../../styles/games/star-savior/ss-builds.css';
import SSCharacterImage from '../../../../components/star-savior/SSCharacterImage.astro';
import SSRarityImage from '../../../../components/star-savior/SSRarityImage.astro';
import SSRoleImage from '../../../../components/star-savior/SSRoleImage.astro';
import SSStatIcon from '../../../../components/star-savior/SSStatIcon.astro';
import SSEquipImage from '../../../../components/star-savior/SSEquipImage.astro';

export function getStaticPaths() {
  return CHARACTER_BUILDS.map(char => ({
    params: { slug: char.slug },
    props: { char },
  }));
}

const { char } = Astro.props;

const STAT_ICON_MAP: Record<string, string> = {
  'ATK %': 'ATK', 'HP %': 'HP', 'DEF %': 'DEF',
  'CRIT Rate': 'Crit Rate', 'CRIT Damage': 'Crit DMG',
  'Effect Hit': 'Effect Hit', 'Effect RES': 'Effect RES',
  SPD: 'SPD', ATK: 'ATK', DEF: 'DEF', 'Flat HP': 'HP',
};

const build = BUILD_TYPES[char.buildType];
const buildLabel = char.buildType === 'dps' ? 'DPS Build' : 'Tank / Support Build';
const tiers = char.substatTiers;

const TIER_LABELS: Record<string, string> = {
  optimal: 'Optimal',
  great: 'Great',
  acceptable: 'Acceptable',
  filler: 'Filler',
};

const TIER_DESCS: Record<string, string> = {
  optimal: char.buildType === 'dps'
    ? 'Hit this 4 times across levels 3, 6, 9, 12 for the best DPS. 2-3 hits is acceptable.'
    : 'Hit this 4 times across levels 3, 6, 9, 12 for maximum survivability.',
  great: char.buildType === 'dps'
    ? 'If you cannot hit ATK%, these are the best alternatives. HP% is very strong.'
    : 'These are excellent secondary choices for survivability and utility.',
  acceptable: 'Decent options if you run out of the above. Minimal impact on performance.',
  filler: 'Anything else. Wont affect your build much.',
};
---

<LandingLayout title={`${char.name} Build - Star Savior`} description={`Equipment build guide for ${char.name} (${char.role}). ${buildLabel} with ${char.set} set.`} gameTitle={`${char.name} Build`}>
  <section class="ss-build-detail-header">
    <div class="ss-build-detail-portrait">
      <SSCharacterImage slug={char.slug} alt={char.name} imageType="portrait" width={280} height={280} />
    </div>
    <div class="ss-build-detail-info">
      <h1 class="ss-build-detail-name">{char.name}</h1>
      <div class="ss-build-detail-badges">
        <SSRarityImage rarity={char.rarity} width={64} height={32} />
        <div class="ss-build-detail-role">
          <SSRoleImage role={char.role} width={24} height={24} />
          <span>{char.role}</span>
        </div>
      </div>
      <div class="ss-build-detail-type-badge ss-build-detail-type-badge--{char.buildType}">
        {buildLabel}
      </div>
      <div class="ss-build-detail-set">
        <span class="ss-build-detail-set-label">Recommended Set</span>
        <span class="ss-build-detail-set-name">{char.set} Set</span>
      </div>
    </div>
  </section>

  <section class="ss-build-detail-section">
    <h2 class="ss-build-detail-heading">Equipment</h2>
    <div class="ss-build-detail-slots">
      {SLOT_ORDER.map(slot => {
        const rec = char.slots[slot];
        if (!rec) return null;
        const isRecommended = rec.recommendedMainStat !== rec.actualMainStat;
        const maxTotal = rec.actualMainStatValue + rec.enchantPerStat * rec.maxEnchantLevel;
        return (
          <div class="ss-build-detail-slot">
            <div class="ss-build-detail-slot-icon">
              <SSEquipImage icon={rec.icon} alt={rec.itemName} width={64} />
            </div>
            <div class="ss-build-detail-slot-info">
              <div class="ss-build-detail-slot-name">{rec.itemName}</div>
              <div class="ss-build-detail-slot-meta">
                <span class="ss-build-detail-slot-grade">T2 Legendary</span>
              </div>
              <div class="ss-build-detail-slot-main">
                <SSStatIcon stat={STAT_ICON_MAP[rec.recommendedMainStat] || rec.recommendedMainStat} size={16} />
                <span class="ss-build-detail-slot-stat-label">{rec.recommendedMainStatLabel}</span>
              </div>
              {!isRecommended && rec.actualMainStatValue > 0 && (
                <div class="ss-build-detail-slot-stat-value">
                  {rec.actualMainStatValue} <span class="ss-build-detail-slot-stat-arrow">&rarr;</span> {rec.actualMainStatValue + rec.enchantPerStat * rec.maxEnchantLevel}
                  <span class="ss-build-detail-slot-stat-lvl">(+{rec.maxEnchantLevel})</span>
                </div>
              )}
              {isRecommended && (
                <span class="ss-build-detail-slot-stat-rec">Recommended</span>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="ss-build-detail-section">
    <h2 class="ss-build-detail-heading">Substats</h2>
    <p class="ss-build-detail-subs-desc">
      New substats unlock at enhancement levels 3, 6, 9, 12 (4 rolls total). Rerolling is not available.
    </p>
    <div class="ss-build-detail-subs-tiers">
      {['optimal', 'great', 'acceptable', 'filler'].map(tier => {
        const stats = tiers[tier];
        if (!stats || stats.length === 0) return null;
        return (
          <div class={`ss-build-detail-tier ss-build-detail-tier--${tier}`}>
            <div class="ss-build-detail-tier-header">
              <span class="ss-build-detail-tier-label">{TIER_LABELS[tier]}</span>
              {TIER_DESCS[tier] && <span class="ss-build-detail-tier-desc">{TIER_DESCS[tier]}</span>}
            </div>
            <div class="ss-build-detail-tier-stats">
              {stats.map(stat => (
                <span class="ss-build-detail-tier-stat">
                  <SSStatIcon stat={STAT_ICON_MAP[stat] || stat} size={16} />
                  <span>{stat}</span>
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</LandingLayout>
