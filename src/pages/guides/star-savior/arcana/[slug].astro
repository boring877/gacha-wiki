---
// Star Savior Individual Arcana Detail Page
import CharacterDetailLayout from '../../../../layouts/star-savior/CharacterDetailLayout.astro';
import { STAR_SAVIOR_ARCANA } from '../../../../data/star-savior/arcana.js';
import { ARCANA_JOURNEY_BG_MAP } from '../../../../data/star-savior/arcana-journey-bg.js';

import '../../../../styles/games/star-savior/ss-character-detail.css';
import '../../../../styles/games/star-savior/ss-arcana-detail.css';
import SSArcanaImage from '../../../../components/star-savior/SSArcanaImage.astro';
import SSRarityImage from '../../../../components/star-savior/SSRarityImage.astro';
import SSArcanaTagImage from '../../../../components/star-savior/SSArcanaTagImage.astro';
import SSNurtureRoleImage from '../../../../components/star-savior/SSNurtureRoleImage.astro';
import SSStatIcon from '../../../../components/star-savior/SSStatIcon.astro';
import SSPotentialIcon from '../../../../components/star-savior/SSPotentialIcon.astro';
import SSArcanaUniqueEffects from '../../../../components/star-savior/SSArcanaUniqueEffects.astro';
import SSArcanaPromotions from '../../../../components/star-savior/SSArcanaPromotions.astro';
import SSJourneyBgGallery from '../../../../components/star-savior/SSJourneyBgGallery.astro';

export function getStaticPaths() {
  return STAR_SAVIOR_ARCANA.map((a) => ({
    params: { slug: a.slug },
  }));
}

const { slug } = Astro.params;

const arcanaInfo = STAR_SAVIOR_ARCANA.find((a: any) => a.slug === slug);

if (!arcanaInfo) {
  return Astro.redirect('/guides/star-savior/arcana/');
}

const data = (await import(`../../../../data/star-savior/arcana/${slug}.json`)).default || {};

const STAT_ICON_MAP: Record<string, string> = {
  Power: 'ATK',
  Health: 'HP',
  Focus: 'Effect Hit',
  Endurance: 'DEF',
  Protect: 'Effect RES',
};

const promotions: any[] = data.promotions || [];
const uniqueEffects: any[] = data.uniqueEffects || [];
const journeyEvents: any[] = data.journeyEvents || [];
const journeyBgFiles = ARCANA_JOURNEY_BG_MAP[slug] || [];

const description = `${data.name || data.character} - ${data.grade} Arcana in Star Savior.`;

const allSEPotentials: any[] = [];
journeyEvents.forEach((je: any) => {
  if (je.rewards) {
    je.rewards.forEach((r: any) => {
      if (r.type === 'SE Potential' && r.name && !allSEPotentials.find((p: any) => p.name === r.name)) {
        allSEPotentials.push(r);
      }
    });
  }
});
---

<CharacterDetailLayout title={data.name || data.character} description={description} gameTitle={data.name || data.character}>
  <div class="ss-detail-header">
    <div class="ss-detail-portrait-container">
      <SSArcanaImage image={data.image} alt={data.name || data.character} width={480} class="ss-detail-portrait-wrapper" />
    </div>
    <div class="ss-detail-info">
      <h2 class="ss-detail-name">{data.name || '--'}</h2>
      <div class="ss-detail-meta">
        <SSRarityImage rarity={data.grade} width={60} height={30} />
        {data.statTag && (
          <div class="ss-detail-role-badge">
            <SSStatIcon stat={STAT_ICON_MAP[data.statTag] || data.statTag} size={24} />
            <span>{data.statTag}</span>
          </div>
        )}
      </div>
      <div class="ss-detail-title">{data.character}</div>
      {data.grade === 'SSR' && (
        <div class="ss-detail-arcana-tags">
          {data.specialTag && (
            <div class="ss-detail-tag">
              <SSArcanaTagImage tag={data.specialTag} width={24} height={24} />
              <div>
                <div class="ss-detail-tag-label">Special Tag</div>
                <div class="ss-detail-tag-value">{data.specialTag}</div>
              </div>
            </div>
          )}
          {data.classSynergy && (
            <div class="ss-detail-tag">
              <SSNurtureRoleImage role={data.classSynergy} width={24} height={24} />
              <div>
                <div class="ss-detail-tag-label">Class Synergy</div>
                <div class="ss-detail-tag-value">{data.classSynergy}</div>
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </div>

  <div class="ss-arcana-overview">
    <p>Arcana are cards that provide passive bonuses during <strong>Journey mode</strong>. They boost your stats at the start of each run, improve training and class training efficiency, grant combat advantages through Special Tags, and unlock story events that reward stats, stamina, and potential points.</p>
    <p>Higher grade arcana (SSR, SR) offer more effects -- Special Tags for combat buffs, Class Synergy for +5% Training Effect with specific classes, Unique Effects that spend Bond Points for extra gains, and Journey Event story chains with rewards.</p>
  </div>

  {allSEPotentials.length > 0 && (
    <section class="content-section">
      <h2 class="section-title">Potential</h2>
      <p class="ss-arcana-potential-intro">Earned from Journey Events. Grants a permanent passive skill enhancement.</p>
      <div class="ss-arcana-potential-list">
        {allSEPotentials.map((p: any) => (
          <div class="ss-arcana-potential-card">
            <div class="ss-arcana-potential-icon">
              {p.icon ? <SSPotentialIcon icon={p.icon} alt={p.name} size={48} /> : <span>?</span>}
            </div>
            <div class="ss-arcana-potential-text">
              <div class="ss-arcana-potential-name">
                {p.name}
                {p.role && <span class="ss-arcana-potential-role">{p.role}</span>}
              </div>
              <div class="ss-arcana-potential-desc">{p.description}</div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <SSArcanaUniqueEffects uniqueEffects={uniqueEffects} />

  {journeyEvents.length > 0 && (
    <section class="content-section">
      <h2 class="section-title">Journey Events</h2>
      <div class="ss-arcana-event-list">
        {journeyEvents.map((je: any, idx: number) => (
          <div class="ss-arcana-event-item">
            <div class="ss-arcana-event-num">{idx + 1}</div>
            <div class="ss-arcana-event-info">
              <div class="ss-arcana-event-title">{je.title || `Event ${je.cutsceneId}`}</div>
              {je.rewards && je.rewards.length > 0 && (
                <div class="ss-arcana-event-rewards">
                  {je.rewards.map((r: any, ri: number) => (
                    <span class="ss-arcana-event-reward-tag">
                      {r.type === 'Stat' && `${r.stat} +${r.value}`}
                      {r.type === 'Stamina' && `Stamina +${r.value}`}
                      {r.type === 'Potential Points' && `Potential +${r.value}`}
                      {r.type === 'Coins' && `Coins +${r.value}`}
                      {r.type === 'Condition' && `Condition +${r.value}`}
                      {r.type === 'SE Potential' && r.name && r.name}
                      {r.type === 'SE Potential' && !r.name && `SE Potential x${r.value}`}
                      {r.type === 'Stat Potential' && `Stat Potential x${r.value}`}
                      {r.type === 'Journey Buff' && `Buff`}
                      {r.type === 'Item' && `Item x${r.value}`}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <SSArcanaPromotions promotions={promotions} />

  {data.episode && (
    <section class="content-section">
      <h2 class="section-title">Episode</h2>
      <div class="ss-arcana-episode">
        {data.episode.split('\n').map((line: string) => line ? <p>{line}</p> : <br />)}
      </div>
    </section>
  )}

  {journeyBgFiles.length > 0 && (
    <SSJourneyBgGallery files={journeyBgFiles} />
  )}
</CharacterDetailLayout>
