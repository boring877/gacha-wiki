---
// Star Savior Arcana Database Page
// Displays all 67 arcana with filters (grade, special tag, class synergy, stat tag) and sort
import CharacterDatabaseLayout from '../../../../layouts/star-savior/CharacterDatabaseLayout.astro';
import { STAR_SAVIOR_ARCANA } from '../../../../data/star-savior/arcana.js';
import { STAR_SAVIOR_CHARACTERS } from '../../../../data/star-savior/characters.js';

import '../../../../styles/games/star-savior/ss-character-database.css';
import SSArcanaImage from '../../../../components/star-savior/SSArcanaImage.astro';
import SSRarityImage from '../../../../components/star-savior/SSRarityImage.astro';
import SSArcanaTagImage from '../../../../components/star-savior/SSArcanaTagImage.astro';
import SSNurtureRoleImage from '../../../../components/star-savior/SSNurtureRoleImage.astro';
import SSStatIcon from '../../../../components/star-savior/SSStatIcon.astro';

const STAT_ICON_MAP: Record<string, string> = {
  Power: 'ATK',
  Health: 'HP',
  Focus: 'Effect Hit',
  Endurance: 'DEF',
  Protect: 'Effect RES',
};

const specialTags = [...new Set(STAR_SAVIOR_ARCANA.map(a => a.specialTag).filter(Boolean))].sort();
const classSynergies = [...new Set(STAR_SAVIOR_ARCANA.map(a => a.classSynergy).filter(Boolean))].sort();
const statTags = [...new Set(STAR_SAVIOR_ARCANA.map(a => a.statTag).filter(Boolean))].sort();

const ssrCount = STAR_SAVIOR_ARCANA.filter(a => a.grade === 'SSR').length;
const srCount = STAR_SAVIOR_ARCANA.filter(a => a.grade === 'SR').length;
const rCount = STAR_SAVIOR_ARCANA.filter(a => a.grade === 'R').length;

const sorted = [...STAR_SAVIOR_ARCANA].sort((a, b) => {
  const r = { SSR: 0, SR: 1, R: 2 };
  if (r[a.grade] !== r[b.grade]) return r[a.grade] - r[b.grade];
  return a.name.localeCompare(b.name);
});

const charMap = new Map<string, string>();
for (const c of STAR_SAVIOR_CHARACTERS) {
  const key = c.name + (c.title ? ` - ${c.title}` : '');
  if (!charMap.has(c.name)) charMap.set(c.name, key);
}

function getCharFullName(name: string): string {
  return charMap.get(name) || name;
}
---

<CharacterDatabaseLayout
  title="Arcana Database - Star Savior"
  description="Complete arcana database for Star Savior. View all 67 arcana with grades, special tags, class synergies, and stat tags."
  gameTitle="Arcana Database"
>
  <div class="ss-char-stats-bar">
    <div class="ss-char-stats-item">
      <div class="ss-char-stats-value">{STAR_SAVIOR_ARCANA.length}</div>
      <div class="ss-char-stats-label">Total</div>
    </div>
    <div class="ss-char-stats-divider"></div>
    <div class="ss-char-stats-item">
      <div class="ss-char-stats-value">{ssrCount}</div>
      <div class="ss-char-stats-label">SSR</div>
    </div>
    <div class="ss-char-stats-divider"></div>
    <div class="ss-char-stats-item">
      <div class="ss-char-stats-value">{srCount}</div>
      <div class="ss-char-stats-label">SR</div>
    </div>
    <div class="ss-char-stats-divider"></div>
    <div class="ss-char-stats-item">
      <div class="ss-char-stats-value">{rCount}</div>
      <div class="ss-char-stats-label">R</div>
    </div>
  </div>

  <div class="ss-char-filter-section">
    <div class="ss-char-filter-row">
      <div class="ss-char-filter-group">
        <label class="ss-char-filter-label">Search</label>
        <input type="text" id="arcana-search" class="ss-char-filter-input" placeholder="Search by name or character..." />
      </div>
      <div class="ss-char-filter-group">
        <label class="ss-char-filter-label">Grade</label>
        <select id="filter-grade" class="ss-char-filter-input">
          <option value="">All</option>
          <option value="SSR">SSR</option>
          <option value="SR">SR</option>
          <option value="R">R</option>
        </select>
      </div>
      <div class="ss-char-filter-group">
        <label class="ss-char-filter-label">Special Tag</label>
        <select id="filter-special-tag" class="ss-char-filter-input">
          <option value="">All</option>
          {specialTags.map(t => <option value={t}>{t}</option>)}
        </select>
      </div>
      <div class="ss-char-filter-group">
        <label class="ss-char-filter-label">Class Synergy</label>
        <select id="filter-class-synergy" class="ss-char-filter-input">
          <option value="">All</option>
          {classSynergies.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div class="ss-char-filter-group">
        <label class="ss-char-filter-label">Stat Tag</label>
        <select id="filter-stat-tag" class="ss-char-filter-input">
          <option value="">All</option>
          {statTags.map(s => <option value={s}>{s}</option>)}
        </select>
      </div>
    </div>
  </div>

  <div class="ss-char-sort-section">
    <span class="ss-char-sort-label">Sort by:</span>
    <button class="ss-char-sort-btn active" data-sort="name">Name <span class="ss-char-sort-icon">▲</span></button>
    <button class="ss-char-sort-btn" data-sort="grade">Grade <span class="ss-char-sort-icon">▲</span></button>
    <button class="ss-char-sort-btn" data-sort="character">Character <span class="ss-char-sort-icon">▲</span></button>
  </div>

  <div class="ss-char-table-wrapper" id="table-view">
    <table class="ss-char-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Arcana</th>
          <th>Character</th>
          <th>Grade</th>
          <th>Special Tag</th>
          <th>Class Synergy</th>
          <th>Stat Tag</th>
        </tr>
      </thead>
      <tbody id="arcana-table-body">
        {sorted.map((arcana, i) => (
          <tr
            class="arcana-row"
            data-slug={arcana.slug}
            data-name={(arcana.name || arcana.character).toLowerCase()}
            data-character={arcana.character.toLowerCase()}
            data-grade={arcana.grade}
            data-special-tag={arcana.specialTag || ''}
            data-class-synergy={arcana.classSynergy || ''}
            data-stat-tag={arcana.statTag || ''}
            onclick={`window.location.href='/guides/star-savior/arcana/${arcana.slug}/'`}
          >
            <td class="row-num">{i + 1}</td>
            <td>
              <div class="ss-char-table-char">
                <SSArcanaImage imageSmall={arcana.imageSmall} alt={arcana.name || arcana.character} width={192} class="ss-char-table-avatar" />
                <div>
                  <div class="ss-char-table-name">{arcana.name || '--'}</div>
                </div>
              </div>
            </td>
            <td>
              <div class="ss-char-table-name">{getCharFullName(arcana.character)}</div>
            </td>
            <td><SSRarityImage rarity={arcana.grade} width={32} height={16} /></td>
            <td>
              {arcana.specialTag
                ? <div class="ss-table-icon-cell"><SSArcanaTagImage tag={arcana.specialTag} width={20} height={20} /><span>{arcana.specialTag}</span></div>
                : <span class="ss-table-dash">--</span>
              }
            </td>
            <td>
              {arcana.classSynergy
                ? <div class="ss-table-icon-cell"><SSNurtureRoleImage role={arcana.classSynergy} width={20} height={20} /><span>{arcana.classSynergy}</span></div>
                : <span class="ss-table-dash">--</span>
              }
            </td>
            <td>
              {arcana.statTag
                ? <div class="ss-table-icon-cell"><SSStatIcon stat={STAT_ICON_MAP[arcana.statTag] || arcana.statTag} size={20} /><span>{arcana.statTag}</span></div>
                : <span class="ss-table-dash">--</span>
              }
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="ss-char-grid" id="grid-view">
    {sorted.map((arcana) => (
      <div
        class="ss-char-card arcana-card"
        data-slug={arcana.slug}
        data-name={(arcana.name || arcana.character).toLowerCase()}
        data-character={arcana.character.toLowerCase()}
        data-grade={arcana.grade}
        data-special-tag={arcana.specialTag || ''}
        data-class-synergy={arcana.classSynergy || ''}
        data-stat-tag={arcana.statTag || ''}
        onclick={`window.location.href='/guides/star-savior/arcana/${arcana.slug}/'`}
      >
        <div class="ss-char-card-header ss-arcana-card-layout">
          <SSArcanaImage imageSmall={arcana.imageSmall} alt={arcana.name || arcana.character} width={320} class="ss-char-card-avatar" />
          <div class="ss-char-card-info">
            <div class="ss-char-card-name">{arcana.name || '--'}</div>
            <div class="ss-arcana-card-arcana-name">{getCharFullName(arcana.character)}</div>
            <div class="ss-char-card-badges">
              <SSRarityImage rarity={arcana.grade} width={48} height={24} />
              {arcana.specialTag && <SSArcanaTagImage tag={arcana.specialTag} width={20} height={20} class="ss-element-inline" />}
              {arcana.classSynergy && <SSNurtureRoleImage role={arcana.classSynergy} width={20} height={20} class="ss-element-inline" />}
              {arcana.statTag && <SSStatIcon stat={STAT_ICON_MAP[arcana.statTag] || arcana.statTag} size={20} class="ss-element-inline" />}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="ss-char-no-results" id="no-results">
    <div class="ss-char-stats-value">?</div>
    <div>No arcana found</div>
    <div style="font-size:0.875rem;opacity:0.7;margin-top:0.25rem">Try adjusting your filters</div>
  </div>
</CharacterDatabaseLayout>

<style>
  .ss-arcana-card-layout {
    flex-direction: column;
  }

  .ss-arcana-card-layout .ss-char-card-avatar {
    width: 100% !important;
  }

  .ss-arcana-card-layout .ss-char-card-info {
    padding: 0.75rem;
  }

  .ss-arcana-card-arcana-name {
    font-size: 0.75rem;
    color: var(--ss-text-secondary);
    margin: 0 0 0.25rem 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ss-table-icon-cell {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .ss-table-icon-cell span {
    font-size: 0.8125rem;
    white-space: nowrap;
  }

  .ss-table-dash {
    color: var(--ss-text-muted);
    opacity: 0.5;
  }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const searchInput = document.getElementById('arcana-search');
  const gradeFilter = document.getElementById('filter-grade');
  const specialTagFilter = document.getElementById('filter-special-tag');
  const classSynergyFilter = document.getElementById('filter-class-synergy');
  const statTagFilter = document.getElementById('filter-stat-tag');
  const sortBtns = document.querySelectorAll('.ss-char-sort-btn');
  const noResults = document.getElementById('no-results');
  const tableRows = document.querySelectorAll('.arcana-row');
  const gridCards = document.querySelectorAll('.arcana-card');

  let currentSort = 'name';
  let currentOrder = 'asc';

  function applyFilters() {
    const search = searchInput.value.toLowerCase();
    const grade = gradeFilter.value;
    const specialTag = specialTagFilter.value;
    const classSynergy = classSynergyFilter.value;
    const statTag = statTagFilter.value;
    let visible = 0;

    tableRows.forEach(row => {
      const match = matchesFilter(row, search, grade, specialTag, classSynergy, statTag);
      row.style.display = match ? '' : 'none';
      if (match) { visible++; row.querySelector('.row-num').textContent = visible; }
    });

    gridCards.forEach(card => {
      const match = matchesFilter(card, search, grade, specialTag, classSynergy, statTag);
      card.style.display = match ? '' : 'none';
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  function matchesFilter(el, search, grade, specialTag, classSynergy, statTag) {
    return (!search || (el.dataset.name || '').includes(search) || (el.dataset.character || '').includes(search))
      && (!grade || el.dataset.grade === grade)
      && (!specialTag || el.dataset.specialTag === specialTag)
      && (!classSynergy || el.dataset.classSynergy === classSynergy)
      && (!statTag || el.dataset.statTag === statTag);
  }

  function applySort(sortBy, order) {
    const tbody = document.getElementById('arcana-table-body');
    const rows = Array.from(tableRows);
    const cards = Array.from(gridCards);

    rows.sort((a, b) => compareValues(a, b, sortBy, order));
    rows.forEach((row, i) => { tbody.appendChild(row); row.querySelector('.row-num').textContent = i + 1; });

    cards.sort((a, b) => compareValues(a, b, sortBy, order));
    const gridEl = document.getElementById('grid-view');
    cards.forEach(card => gridEl.appendChild(card));
  }

  function compareValues(a, b, sortBy, order) {
    let valA, valB;
    if (sortBy === 'grade') {
      const ro = { SSR: 0, SR: 1, R: 2 };
      valA = ro[a.dataset.grade] ?? 99;
      valB = ro[b.dataset.grade] ?? 99;
      if (order === 'asc') return valA - valB;
      return valB - valA;
    }
    valA = a.dataset[sortBy] || '';
    valB = b.dataset[sortBy] || '';
    if (order === 'asc') return valA.localeCompare(valB);
    return valB.localeCompare(valA);
  }

  searchInput.addEventListener('input', applyFilters);
  gradeFilter.addEventListener('change', applyFilters);
  specialTagFilter.addEventListener('change', applyFilters);
  classSynergyFilter.addEventListener('change', applyFilters);
  statTagFilter.addEventListener('change', applyFilters);

  sortBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const sortBy = btn.dataset.sort;
      let order = currentSort === sortBy && currentOrder === 'asc' ? 'desc' : 'asc';

      sortBtns.forEach(b => { b.classList.remove('active'); b.querySelector('.ss-char-sort-icon').textContent = '▲'; });
      btn.classList.add('active');
      btn.querySelector('.ss-char-sort-icon').textContent = order === 'asc' ? '▲' : '▼';

      currentSort = sortBy;
      currentOrder = order;
      applySort(sortBy, order);
      applyFilters();
    });
  });
});
</script>
