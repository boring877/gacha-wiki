---
import CharacterIndividualLayout from '../../../../layouts/horizon-walker/CharacterIndividualLayout.astro';
import CharacterPageTemplate from '../../../../templates/horizon-walker/CharacterPageTemplate.astro';
import {
  hongpamangData,
  hongpamangSEO,
  hongpamangHighlighting,
} from '../../../../data/horizon-walker/characters/hongpamang.js';

export const prerender = true;
---

<CharacterIndividualLayout
  title={hongpamangSEO.title}
  description={hongpamangSEO.description}
  gameTitle={hongpamangData.name}
  character={hongpamangData}
>
  <CharacterPageTemplate characterData={{ ...hongpamangData, highlightPatterns: hongpamangHighlighting }} />
</CharacterIndividualLayout>
