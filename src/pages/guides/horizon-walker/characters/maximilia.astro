---
import CharacterIndividualLayout from '../../../../layouts/horizon-walker/CharacterIndividualLayout.astro';
import CharacterPageTemplate from '../../../../templates/horizon-walker/CharacterPageTemplate.astro';
import {
  maximiliaData,
  maximiliaSEO,
  maximiliaHighlighting,
} from '../../../../data/horizon-walker/characters/maximilia.js';

export const prerender = true;
---

<CharacterIndividualLayout
  title={maximiliaSEO.title}
  description={maximiliaSEO.description}
  gameTitle={maximiliaData.name}
  character={maximiliaData}
>
  <CharacterPageTemplate characterData={{ ...maximiliaData, highlightPatterns: maximiliaHighlighting }} />
</CharacterIndividualLayout>
