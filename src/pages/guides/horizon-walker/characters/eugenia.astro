---
import CharacterIndividualLayout from '../../../../layouts/horizon-walker/CharacterIndividualLayout.astro';
import CharacterPageTemplate from '../../../../templates/horizon-walker/CharacterPageTemplate.astro';
import {
  eugeniaData,
  eugeniaSEO,
  eugeniaHighlighting,
} from '../../../../data/horizon-walker/characters/eugenia.js';

export const prerender = true;
---

<CharacterIndividualLayout
  title={eugeniaSEO.title}
  description={eugeniaSEO.description}
  gameTitle={eugeniaData.name}
  character={eugeniaData}
>
  <CharacterPageTemplate characterData={{ ...eugeniaData, highlightPatterns: eugeniaHighlighting }} />
</CharacterIndividualLayout>
