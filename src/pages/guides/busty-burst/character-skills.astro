---
import CharacterSkillsLayout from '../../../layouts/busty-burst/CharacterSkillsLayout.astro';
import PaladinImage from '../../../components/busty-burst/PaladinImage.astro';
import ElementImage from '../../../components/busty-burst/ElementImage.astro';
import PositionImage from '../../../components/busty-burst/PositionImage.astro';
import TypeofATKImage from '../../../components/busty-burst/TypeofATKImage.astro';
import RarityImage from '../../../components/busty-burst/RarityImage.astro';
import SkillIcon from '../../../components/busty-burst/SkillIcon.astro';
import WeaponIcon from '../../../components/busty-burst/WeaponIcon.astro';
import { BUSTY_BURST_SKILLS_DATA, SPEED_LABELS, getCharacterBySlug, getAllCharacterSlugs } from '../../../data/busty-burst/characters/index.js';
import { getSupportDataById } from '../../../data/busty-burst/support-data.js';

const getWeaponType = (charId: number) => {
  const supportData = getSupportDataById(charId);
  return supportData?.weapon || null;
};

const getCharacterPosition = (slug: string) => {
  const charInfo = getCharacterBySlug(slug);
  return charInfo?.position?.number || 1;
};

const getPositionFileName = (pos: number) => {
  const posMap: Record<number, string> = { 1: 'Front.png', 2: 'Mid.png', 3: 'Back.png' };
  return posMap[pos] || 'Front.png';
};

const getPositionLabel = (pos: number) => {
  const posMap: Record<number, string> = { 1: 'Front', 2: 'Mid', 3: 'Back' };
  return posMap[pos] || 'Front';
};

const validCharacterSlugs = new Set(getAllCharacterSlugs());
const rarityOrder: Record<string, number> = { 'SSR': 0, 'SR': 1, 'R': 2 };
const characterSkills = [...BUSTY_BURST_SKILLS_DATA]
  .filter(c => validCharacterSlugs.has(c.slug))
  .sort((a, b) => (rarityOrder[a.rarity] ?? 99) - (rarityOrder[b.rarity] ?? 99) || a.name.localeCompare(b.name));

const charCounts = {
  total: characterSkills.length,
  SSR: characterSkills.filter(c => c.rarity === 'SSR').length,
  SR: characterSkills.filter(c => c.rarity === 'SR').length,
  R: characterSkills.filter(c => c.rarity === 'R').length,
};

const STATUS_EFFECT_INFO: Record<string, string> = {
  'petrify': 'Cannot act, Block=0',
  'stun': 'Cannot act',
  'freeze': 'Cannot act + DoT',
  'sleep': 'Cannot act, wakes on hit (CRIT)',
  'silence': 'No skills/ult',
  'confusion': 'Attacks random targets',
  'charm': 'Attacks allies',
  'taunt': 'Must attack taunter',
  'poison': 'DoT',
  'burn': 'DoT, stackable',
  'bleed': 'DoT (-1% HP)',
  'paralysis': 'Speed -50%, ATK -50%',
  'curse': 'No recovery, Speed -50%, Crit=0',
  'blind': 'Block=0, Acc -50%',
  'fear': 'MP drain',
};

const highlightValues = (text: string) => {
  if (!text) return '';
  let result = text;

  result = result.replace(/for (\d+\.?\d*) seconds?/gi, 'for <span class="bb-kw-duration">$1s</span>');

  for (const [effect, desc] of Object.entries(STATUS_EFFECT_INFO)) {
    const regex = new RegExp(`\\b(${effect})\\b(?!\\s*<span)`, 'gi');
    result = result.replace(regex, `<span class="bb-kw-status">$1</span> <span class="bb-kw-hint">(${desc})</span>`);
  }

  result = result
    .replace(/\b(heal(?:s|ing)?)\b/gi, '<span class="bb-kw-heal">$1</span>')
    .replace(/\b(restores?)\s*(hp)\b/gi, '<span class="bb-kw-heal">$1 $2</span>')
    .replace(/\b(applies?)\b/gi, '<span class="bb-kw-apply">$1</span>')
    .replace(/\b(inflicts?)\b/gi, '<span class="bb-kw-inflict">$1</span>')
    .replace(/\b(deals?)\b/gi, '<span class="bb-kw-damage">$1</span>')
    .replace(/\b(absorbs?)\b/gi, '<span class="bb-kw-absorb">$1</span>')
    .replace(/\b(removes?)\s*(debuff|all debuff)/gi, '<span class="bb-kw-cleanse">$1 $2</span>')
    .replace(/\b(dispel)\b/gi, '<span class="bb-kw-cleanse">$1</span>');

  result = result
    .replace(/(\d+(?:\.\d+)?)%/g, '<span class="bb-kw-num">$1</span>%')
    .replace(/(\+\d+(?:\.\d+)?)(?!\s*%)/g, '<span class="bb-kw-num">$1</span>');

  return result;
};

const formatBuffEffect = (b: any) => {
  if (!b || (b.value === 0 && b.type === 'unknown')) return '';
  const sign = b.value > 0 ? '+' : '';
  const val = typeof b.value === 'number' ? `${sign}${b.value}` : '';
  const suffix = b.type === 'percent' ? '%' : '';
  const needsSpace = !b.name.endsWith('+') && !b.name.endsWith('-') && val ? ' ' : '';
  return `${b.name}${needsSpace}${val}${suffix}`;
};

const title = 'Busty Burst Character Skills Guide';
const description = `Complete skill guide for all ${characterSkills.length} Busty Burst characters.`;
const gameTitle = 'Character Skills Guide';

const elements = [...new Set(characterSkills.map(c => c.element))].sort();
const roles = [...new Set(characterSkills.map(c => c.role))].sort();
const rarities = ['SSR', 'SR', 'R'];
---

<CharacterSkillsLayout title={title} description={description} gameTitle={gameTitle}>
  <div class="bb-skills-page">
    <!-- Statistics Overview -->
    <div class="bb-skills-stats-container">
      <div class="bb-skills-stat-item">
        <div class="bb-skills-stat-value">{charCounts.total}</div>
        <div class="bb-skills-stat-label">Total</div>
      </div>
      <div class="bb-skills-stat-divider"></div>
      <div class="bb-skills-stat-item">
        <div class="bb-skills-stat-value">{charCounts.SSR}</div>
        <div class="bb-skills-stat-label">SSR</div>
      </div>
      <div class="bb-skills-stat-divider"></div>
      <div class="bb-skills-stat-item">
        <div class="bb-skills-stat-value">{charCounts.SR}</div>
        <div class="bb-skills-stat-label">SR</div>
      </div>
      <div class="bb-skills-stat-divider"></div>
      <div class="bb-skills-stat-item">
        <div class="bb-skills-stat-value">{charCounts.R}</div>
        <div class="bb-skills-stat-label">R</div>
      </div>
    </div>

    <!-- Filter Section -->
    <div class="bb-skills-filter-section">
      <div class="bb-skills-filter-row">
        <div class="bb-skills-filter-group">
          <label class="bb-skills-filter-label" for="skills-search">Search</label>
          <input type="text" id="skills-search" class="bb-skills-search-input" placeholder="Search character or skill..." />
        </div>
        <div class="bb-skills-filter-group">
          <label class="bb-skills-filter-label" for="rarity-filter">Rarity</label>
          <select id="rarity-filter" class="bb-skills-filter-select">
            <option value="">All Rarities</option>
            {rarities.map(r => <option value={r}>{r}</option>)}
          </select>
        </div>
        <div class="bb-skills-filter-group">
          <label class="bb-skills-filter-label" for="element-filter">Element</label>
          <select id="element-filter" class="bb-skills-filter-select">
            <option value="">All Elements</option>
            {elements.map(el => <option value={el}>{el}</option>)}
          </select>
        </div>
        <div class="bb-skills-filter-group">
          <label class="bb-skills-filter-label" for="role-filter">Role</label>
          <select id="role-filter" class="bb-skills-filter-select">
            <option value="">All Roles</option>
            {roles.map(role => <option value={role}>{role}</option>)}
          </select>
        </div>
        <div class="bb-skills-filter-buttons">
          <button type="button" id="clear-filters" class="bb-skills-clear-btn">Clear</button>
        </div>
      </div>
    </div>

    <div class="bb-skills-results-count" id="results-count">
      <span>{characterSkills.length}</span> characters
    </div>

    <div class="bb-skills-grid" id="skills-grid">
      {characterSkills.map(char => (
        <div
          class="bb-skills-card"
          data-name={char.name.toLowerCase()}
          data-element={char.element.toLowerCase()}
          data-role={char.role.toLowerCase()}
          data-rarity={char.rarity.toLowerCase()}
        >
          <div class="bb-card-header" data-toggle="card">
            <div class="bb-skills-portrait">
              <PaladinImage characterId={char.id} alt={char.name} width={512} height={512} format="png" />
              <div class="bb-skills-rarity"><RarityImage rarity={char.rarity} width={56} height={28} /></div>
            </div>
            <div class="bb-skills-info">
              <h2 class="bb-skills-name">{char.name}</h2>
              <div class="bb-skills-details">
                <div class="bb-skills-detail element-badge"><ElementImage element={char.element} width={18} height={18} /><span>{char.element}</span></div>
                <div class="bb-skills-detail role-badge" data-role={char.role.toLowerCase()}>{char.role}</div>
                <div class="bb-skills-detail"><PositionImage fileName={getPositionFileName(getCharacterPosition(char.slug))} alt={getPositionLabel(getCharacterPosition(char.slug))} width={18} height={18} /><span>{getPositionLabel(getCharacterPosition(char.slug))}</span></div>
                <div class="bb-skills-detail"><TypeofATKImage fileName={`${char.basicAttack.type}.png`} alt={char.basicAttack.type} width={18} height={18} /><span>{char.basicAttack.type}</span></div>
                {char.basicAttack.speedLabel && (() => {
                  const speedInfo = SPEED_LABELS[char.basicAttack.speedLabel as keyof typeof SPEED_LABELS];
                  const title = speedInfo ? `Attack freeze time: ${speedInfo.freezeTime}` : '';
                  return <div class="bb-skills-detail speed-badge" title={title}><span class="bb-speed-label">Speed</span><span>{char.basicAttack.speedLabel}</span></div>;
                })()}
                {getWeaponType(char.id) && <div class="bb-skills-detail"><WeaponIcon weapon={getWeaponType(char.id) as string} width={18} height={18} /><span>{getWeaponType(char.id)}</span></div>}
              </div>
            </div>
            <div class="bb-skills-toggle">&#9660;</div>
          </div>

          <div class="bb-card-body">
            <div class="bb-rotation-block">
              <div class="bb-rotation-row">
                <span class="bb-rotation-key">Opening</span>
                <span class="bb-rotation-value">{char.skillRotation.opening || '\u2014'}</span>
              </div>
              <div class="bb-rotation-row">
                <span class="bb-rotation-key">Loop</span>
                <span class="bb-rotation-value">{char.skillRotation.loop}</span>
              </div>
            </div>

            <div class="bb-skill-block">
              <div class="bb-skill-header">
                <SkillIcon skillId={char.basicAttack.icon} alt="Basic" width={40} height={40} />
                <div class="bb-skill-info">
                  <div class="bb-skill-name">Basic Attack</div>
                  <div class="bb-skill-combat-info">
                    <span class="bb-skill-meta-item">{char.basicAttack.scaling}</span>
                    <span class="bb-skill-meta-item">{char.basicAttack.type}</span>
                    {char.basicAttack.speedLabel && <span class="bb-skill-meta-item">{char.basicAttack.speedLabel}{(() => { const si = SPEED_LABELS[char.basicAttack.speedLabel as keyof typeof SPEED_LABELS]; return si ? ` (${si.freezeTime})` : ''; })()}</span>}
                  </div>
                </div>
              </div>
            </div>

            {char.skills.map(skill => {
              const hasDamage = skill.damageScaling && skill.baseDamage != null;
              const baseValue = parseInt(String(skill.baseDamage || '0').replace('+', ''), 10) || 0;
              const growth = parseInt(String(skill.levelGrowth || '0').replace('+', ''), 10) || 0;
              const lvl90Value = baseValue + (90 - 1) * growth;

              const meaningfulBuffs = skill.buffEffects?.filter(b => b.value !== 0 && b.value !== null && b.type !== 'unknown') || [];
              const hasBuffGrowth = meaningfulBuffs.some(b => typeof b.levelGrowth === 'number' && b.levelGrowth !== 0);
              const buffGrowthBuffs = meaningfulBuffs.filter(b => typeof b.levelGrowth === 'number' && b.levelGrowth !== 0);
              const buffGrowthJson = buffGrowthBuffs.length > 0 ? JSON.stringify(buffGrowthBuffs.map(b => ({ name: b.name, value: b.value, growth: b.levelGrowth, type: b.type, valueLv1: b.valueLv1 ?? null, valueLv90: b.valueLv90 ?? null }))) : '';

              let descriptionHtml = skill.description || '';
              if (descriptionHtml) {
                descriptionHtml = highlightValues(descriptionHtml);
              }

              return (
                <div class="bb-skill-block action-skill"
                  data-scaling={skill.damageScaling || ''}
                  data-base={(skill.baseDamage || '0').toString()}
                  data-growth={(skill.levelGrowth || '0').toString()}
                  data-buff-growth={buffGrowthJson}
                  data-has-buff-growth={buffGrowthBuffs.length > 0 ? 'true' : ''}
                >
                  <div class="bb-skill-header">
                    <SkillIcon skillId={skill.icon} alt={skill.name} width={40} height={40} />
                    <div class="bb-skill-info">
                      <div class="bb-skill-name">{skill.name}</div>
                      <div class="bb-skill-combat-info">
                        <span class="bb-skill-meta-item">Skill {skill.slot}</span>
                        {skill.castTime > 0 && <span class="bb-skill-meta-item">Cast {skill.castTime}s</span>}
                        {skill.target && <span class="bb-skill-meta-item">{skill.target}</span>}
                      </div>
                    </div>
                  </div>
                  {descriptionHtml && <div class="bb-skill-desc" set:html={descriptionHtml} />}
                  {hasDamage ? (
                    <div class="bb-skill-calc">
                      <span class="bb-calc-lbl">Lv</span>
                      <input type="number" class="skill-level-input" min="1" max="90" value="90" />
                      <span class="bb-calc-eq">=</span>
                      <span class="bb-calc-formula">{skill.damageScaling}</span>
                      <span class="bb-calc-eq">+</span>
                      <span class="bb-calc-formula">{baseValue}{growth > 0 ? ` + (${89} \u00d7 ${growth})` : ''}</span>
                      <span class="bb-calc-eq">=</span>
                      <span class="bb-calc-value">{lvl90Value}</span>
                     </div>
                   ) : null}
                  {hasBuffGrowth ? (
                    <div class="bb-skill-calc bb-buff-growth-calc">
                      <span class="bb-calc-lbl">Lv</span>
                      <input type="number" class="skill-level-input" min="1" max="90" value="90" />
                      <span class="bb-calc-eq">=</span>
                      <span class="bb-calc-values">
                        {buffGrowthBuffs.map(b => {
                          const base = b.type === 'percent' ? 0 : b.value;
                          const lvl90 = base + 90 * b.growth;
                          return <span class="bb-calc-value">{b.name}: <span class="bb-buff-calc-val">{lvl90}</span></span>;
                        })}
                      </span>
                    </div>
                  ) : null}
                  {meaningfulBuffs.length > 0 && (
                    <div class="bb-skill-buffs">
                      {meaningfulBuffs.map(b => (
                        <span class="bb-skill-buff-tag">{formatBuffEffect(b)}</span>
                      ))}
                    </div>
                  )}
                </div>
              );
            })}

            <div class="bb-skill-block bb-ult-block" data-ult-ranks={JSON.stringify(char.ultimate.map(ult => ({
              rank: ult.rank,
              name: ult.name,
              description: ult.description || '',
              effect: ult.effect || '',
              buffEffects: ult.buffEffects || [],
            })))}>
              <div class="bb-skill-header">
                <SkillIcon skillId={char.ultimate[0].icon} alt="Ult" width={40} height={40} />
                <div class="bb-skill-info">
                  <div class="bb-skill-name">{char.ultimate[0].name}</div>
                  <div class="bb-skill-combat-info">
                    <span class="bb-skill-meta-item">Ultimate</span>
                  </div>
                </div>
              </div>
              <div class="bb-ult-desc" set:html={highlightValues(char.ultimate[0].description || '')} />
              <div class="bb-ult-rank-tabs">
                {char.ultimate.map(ult => (
                  <button type="button" class="bb-ult-tab" data-rank={ult.rank} data-name={ult.name} data-desc={ult.description || ''} data-effect={ult.effect || ''} data-buffs={JSON.stringify(ult.buffEffects?.filter(b => b.value !== 0 && b.value !== null && b.type !== 'unknown').map(b => formatBuffEffect(b)) || [])}>
                    R{ult.rank}
                  </button>
                ))}
              </div>
              <div class="bb-ult-selected">
                <div class="bb-ult-selected-effect" set:html={highlightValues(char.ultimate[0].effect || '')} />
                {(() => {
                  const r0 = char.ultimate[0];
                  const buffList = r0.buffEffects?.filter(b => b.value !== 0 && b.value !== null && b.type !== 'unknown')
                    .map(b => formatBuffEffect(b)) || [];
                  return buffList.length > 0 ? <div class="bb-ult-selected-buffs">{buffList.map(b => <span class="bb-ult-buff-tag">{b}</span>)}</div> : null;
                })()}
              </div>
            </div>

            {char.passives && char.passives.length > 0 && (
              <div class="bb-passives-section">
                {char.passives.map(passive => {
                  const effectList = passive.effects || passive.effectValues || [];
                  return (
                    <div class="bb-skill-block bb-passive-block">
                      <div class="bb-skill-header">
                        <SkillIcon skillId={passive.icon} alt="Passive" width={40} height={40} />
                        <div class="bb-skill-info">
                          <div class="bb-skill-name">{passive.name || 'Passive'}</div>
                          <div class="bb-passive-effects">
                            {effectList.map(e => (
                              <span class="bb-passive-badge">{e.name.replace(/\s*[+]\s*$/, '')} <span class="bb-passive-val">+{e.value}{e.type === 'percent' ? '%' : ''}</span></span>
                            ))}
                          </div>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="bb-skills-no-results" id="no-results">
      <h3>No characters found</h3>
      <p>Try adjusting your search or filter.</p>
    </div>
  </div>
</CharacterSkillsLayout>

<script>
  function initCardToggles() {
    const grid = document.getElementById('skills-grid');
    if (!grid) return;

    grid.addEventListener('click', (e) => {
      const toggle = (e.target as HTMLElement).closest('[data-toggle="card"]');
      if (toggle) {
        const card = toggle.closest('.bb-skills-card') as HTMLElement;
        if (!card) return;
        const body = card.querySelector('.bb-card-body') as HTMLElement;
        if (!body) return;

        if (card.classList.contains('expanded')) {
          body.style.maxHeight = body.scrollHeight + 'px';
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              body.style.maxHeight = '0px';
              card.classList.remove('expanded');
            });
          });
        } else {
          card.classList.add('expanded');
          body.style.maxHeight = body.scrollHeight + 'px';
          body.addEventListener('transitionend', function handler() {
            if (card.classList.contains('expanded')) {
              body.style.maxHeight = '';
            }
            body.removeEventListener('transitionend', handler);
          });
        }
      }
    });
  }

  function initFilters() {
    const searchInput = document.getElementById('skills-search') as HTMLInputElement;
    const rarityFilter = document.getElementById('rarity-filter') as HTMLSelectElement;
    const elementFilter = document.getElementById('element-filter') as HTMLSelectElement;
    const roleFilter = document.getElementById('role-filter') as HTMLSelectElement;
    const clearBtn = document.getElementById('clear-filters');
    const grid = document.getElementById('skills-grid');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');

    if (!grid) return;
    const cards = grid.querySelectorAll('.bb-skills-card');

    function filterCards() {
      const search = searchInput?.value.toLowerCase() || '';
      const rarity = rarityFilter?.value.toLowerCase() || '';
      const element = elementFilter?.value.toLowerCase() || '';
      const role = roleFilter?.value.toLowerCase() || '';

      let visibleCount = 0;
      cards.forEach(card => {
        const cardEl = card as HTMLElement;
        const matchName = !search || cardEl.dataset.name?.includes(search);
        const matchRarity = !rarity || cardEl.dataset.rarity === rarity;
        const matchElement = !element || cardEl.dataset.element === element;
        const matchRole = !role || cardEl.dataset.role === role;
        const isVisible = matchName && matchRarity && matchElement && matchRole;
        cardEl.classList.toggle('hidden', !isVisible);
        if (isVisible) visibleCount++;
      });

      if (noResults) noResults.classList.toggle('visible', visibleCount === 0);
      if (resultsCount) {
        const span = resultsCount.querySelector('span');
        if (span) span.textContent = visibleCount.toString();
      }
    }

    function clearFilters() {
      if (searchInput) searchInput.value = '';
      if (rarityFilter) rarityFilter.value = '';
      if (elementFilter) elementFilter.value = '';
      if (roleFilter) roleFilter.value = '';
      filterCards();
    }

    searchInput?.addEventListener('input', filterCards);
    rarityFilter?.addEventListener('change', filterCards);
    elementFilter?.addEventListener('change', filterCards);
    roleFilter?.addEventListener('change', filterCards);
    clearBtn?.addEventListener('click', clearFilters);
  }

  function initSkillLevelCalc() {
    const globalLevelInput = document.getElementById('global-level') as HTMLInputElement;
    const skillSections = document.querySelectorAll('.bb-skill-block.action-skill');

    skillSections.forEach(section => {
      const sectionEl = section as HTMLElement;
      const damageInput = section.querySelector('.skill-level-input') as HTMLInputElement;
      const resultEl = section.querySelector('.bb-calc-value') as HTMLElement;
      const hasBuffGrowth = sectionEl.dataset.hasBuffGrowth === 'true';

      if (damageInput && resultEl) {
        const base = parseInt((sectionEl.dataset.base || '0').replace('+', ''), 10) || 0;
        const growth = parseInt((sectionEl.dataset.growth || '0').replace('+', ''), 10) || 0;
        const isDamageCalc = sectionEl.closest('.bb-skill-calc') && !sectionEl.closest('.bb-buff-growth-calc');

        function update() {
          let level = parseInt(damageInput.value, 10) || 1;
          level = Math.max(1, Math.min(90, level));
          damageInput.value = level.toString();

          if (isDamageCalc) {
            resultEl.textContent = (base + (level - 1) * growth).toString();
          } else {
            try {
              const buffs: Array<{name: string; value: number; growth: number; type: string}> = JSON.parse(sectionEl.dataset.buffGrowth || '[]');
              const vals = buffs.map(b => {
                const base = b.type === 'percent' ? 0 : b.value;
                return `${b.name}: ${Math.round(base + level * b.growth)}`;
              });
              resultEl.textContent = vals.join(' | ');
            } catch {}
          }
        }

        update();
        damageInput.addEventListener('input', update);
        damageInput.addEventListener('change', update);
      }
    });

    if (globalLevelInput) {
      globalLevelInput.addEventListener('input', () => {
        const level = globalLevelInput.value;
        skillSections.forEach(section => {
          const input = section.querySelector('.skill-level-input') as HTMLInputElement;
          if (input) {
            input.value = level;
            input.dispatchEvent(new Event('input'));
          }
        });
      });
    }
  }

  function initUltRankTabs() {
    document.addEventListener('click', (e) => {
      const tab = (e.target as HTMLElement).closest('.bb-ult-tab') as HTMLElement;
      if (!tab) return;
      const ultBlock = tab.closest('.bb-ult-block') as HTMLElement;
      if (!ultBlock) return;

      ultBlock.querySelectorAll('.bb-ult-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const descEl = ultBlock.querySelector('.bb-ult-desc') as HTMLElement;
      const effectEl = ultBlock.querySelector('.bb-ult-selected-effect') as HTMLElement;
      const buffsEl = ultBlock.querySelector('.bb-ult-selected-buffs') as HTMLElement;

      const hl = (text: string) => {
        if (!text) return '';
        let r = text;
        r = r.replace(/for (\d+\.?\d*) seconds?/gi, 'for <span class="bb-kw-duration">$1s</span>');
        const effects: Record<string, string> = {
          'petrify': 'Cannot act, Block=0', 'stun': 'Cannot act', 'freeze': 'Cannot act + DoT',
          'sleep': 'Cannot act, wakes on hit (CRIT)', 'silence': 'No skills/ult',
          'confusion': 'Attacks random targets', 'charm': 'Attacks allies', 'taunt': 'Must attack taunter',
          'poison': 'DoT', 'burn': 'DoT, stackable', 'bleed': 'DoT (-1% HP)',
          'paralysis': 'Speed -50%, ATK -50%', 'curse': 'No recovery, Speed -50%, Crit=0',
          'blind': 'Block=0, Acc -50%', 'fear': 'MP drain',
        };
        for (const [ef, d] of Object.entries(effects)) {
          r = r.replace(new RegExp(`\\b(${ef})\\b(?!\\s*<span)`, 'gi'), `<span class="bb-kw-status">$1</span> <span class="bb-kw-hint">(${d})</span>`);
        }
        r = r.replace(/(\d+(?:\.\d+)?)%/g, '<span class="bb-kw-num">$1</span>%');
        return r;
      };

      if (descEl) descEl.innerHTML = hl(tab.dataset.desc || '');
      if (effectEl) effectEl.innerHTML = hl(tab.dataset.effect || '');
      if (buffsEl) {
        try {
          const buffs: string[] = JSON.parse(tab.dataset.buffs || '[]');
          buffsEl.innerHTML = buffs.map(b => `<span class="bb-ult-buff-tag">${b}</span>`).join('');
          buffsEl.style.display = buffs.length ? 'flex' : 'none';
        } catch { buffsEl.style.display = 'none'; }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { initCardToggles(); initFilters(); initSkillLevelCalc(); initUltRankTabs(); });
  } else {
    initCardToggles();
    initFilters();
    initSkillLevelCalc();
    initUltRankTabs();
  }
</script>
