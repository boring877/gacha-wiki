---
// Busty Burst Magic Defense Down Database
// Lists all characters with Magic Defense Down skills, organized by tier
// Separated into Skills (with % + flat values) and Ultimates (LV1-5 scaling)

import DefenseDownLayout from '../../../layouts/busty-burst/DefenseDownLayout.astro';
import PaladinImage from '../../../components/busty-burst/PaladinImage.astro';
import ElementImage from '../../../components/busty-burst/ElementImage.astro';
import RarityImage from '../../../components/busty-burst/RarityImage.astro';
import SkillIcon from '../../../components/busty-burst/SkillIcon.astro';
import { getMagicDefenseDownSkills } from '../../../data/busty-burst/defense-down-data.js';

// Get all magic defense down skills
const allSkills = getMagicDefenseDownSkills();

// Separate into skills and ultimates
const skillBased = allSkills.filter(s => s.sourceType === 'skill');
const ultimates = allSkills.filter(s => s.sourceType === 'ultimate');

// Group skill-based by tier
const sortByValue = (a, b) => {
  if (b.percent !== a.percent) return b.percent - a.percent;
  return (b.flat || 0) - (a.flat || 0);
};
const tierS = skillBased.filter(s => s.tier === 'S').sort(sortByValue);
const tierA = skillBased.filter(s => s.tier === 'A').sort(sortByValue);
const tierB = skillBased.filter(s => s.tier === 'B').sort(sortByValue);
const tierC = skillBased.filter(s => s.tier === 'C').sort(sortByValue);

// Sort ultimates by defense down value (highest first)
// Sort by percent first, then by flat value
const sortedUltimates = [...ultimates].sort((a, b) => {
  const aPercent = (a as any).percent ?? 0;
  const bPercent = (b as any).percent ?? 0;
  if (bPercent !== aPercent) return bPercent - aPercent;
  return ((b as any).flat || 0) - ((a as any).flat || 0);
});

// Get unique elements and rarities for filters
const elements = [...new Set(skillBased.map(s => s.element))].filter(Boolean).sort();
const rarities = ['SSR', 'SR', 'R'];



// Stats
const totalSkills = skillBased.length;
const totalUltimates = sortedUltimates.length;
const uniqueChars = new Set(skillBased.map(s => s.characterId)).size;

const title = 'Magic Defense Down Database (Lv90) - Busty Burst Fantasy';
const description = `Complete database of all ${totalSkills} Magic Defense Down skills at Lv90 in Busty Burst Fantasy. Find the best magic defense shred characters organized by tier (S/A/B/C) with percentage reduction, flat values, and duration.`;
const gameTitle = 'Magic Defense Down Database';
---

<DefenseDownLayout title={title} description={description} gameTitle={gameTitle}>
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Busty Burst Fantasy Magic Defense Down Skills (Lv90)",
      "description": "Complete tier list of all Magic Defense Down skills at max level (Lv90) in Busty Burst Fantasy",
      "numberOfItems": {totalSkills},
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "S Tier - Best Magic DEF Down (-23% -320)",
          "description": "Highest magic defense reduction skills at Lv90"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "A Tier - Strong Magic DEF Down (-21% -220)",
          "description": "Strong magic defense reduction skills at Lv90"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "B Tier - Moderate Magic DEF Down (-18% -210)",
          "description": "Moderate magic defense reduction skills at Lv90"
        }
      ]
    }
  </script>
  <div class="bb-defdown-page">
    <!-- Summary Stats -->
    <div class="bb-defdown-summary">
      <div class="bb-defdown-stat-card">
        <div class="bb-defdown-stat-value">{totalSkills}</div>
        <div class="bb-defdown-stat-label">Skills</div>
      </div>
      <div class="bb-defdown-stat-card">
        <div class="bb-defdown-stat-value">{totalUltimates}</div>
        <div class="bb-defdown-stat-label">Ultimates</div>
      </div>
      <div class="bb-defdown-stat-card">
        <div class="bb-defdown-stat-value">{tierS.length}</div>
        <div class="bb-defdown-stat-label">S Tier</div>
      </div>
      <div class="bb-defdown-stat-card">
        <div class="bb-defdown-stat-value">{tierA.length}</div>
        <div class="bb-defdown-stat-label">A Tier</div>
      </div>
    </div>

    <!-- Info Box -->
    <div class="bb-defdown-info-box">
      <h3 class="bb-defdown-info-title">How Magic Defense Down Works</h3>
      <div class="bb-defdown-info-content">
        <p class="bb-defdown-info-text">
          Magic Defense Down reduces enemy magic defense in two ways: percentage reduction (e.g., -23%) and flat reduction (e.g., -320).
          Higher values mean more magic damage to enemies. All values shown are at Skill Lv90 (max level).
        </p>
        <p class="bb-defdown-info-text">
          Stacking Rules: Debuffs use a category system. Skills are Category B (single-target) or C (multi-target).
          Same-category debuffs don't stack, but different categories CAN stack.
          Combine Skill + Ultimate debuffs for maximum effect. See <a href="/guides/busty-burst/buff-debuff-guide">Buff & Debuff Guide</a> for details.
        </p>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div class="bb-defdown-tabs">
      <button type="button" class="bb-defdown-tab active" data-tab="skills">Skills ({totalSkills})</button>
      <button type="button" class="bb-defdown-tab" data-tab="ultimates">Ultimates ({totalUltimates})</button>
    </div>

    <!-- SKILLS SECTION -->
    <div class="bb-defdown-tab-content active" id="skills-content">
      <!-- Filter Controls -->
      <div class="bb-defdown-controls">
        <div class="bb-defdown-filter-row">
          <input
            type="text"
            id="defdown-search"
            class="bb-defdown-search-input"
            placeholder="Search by character or skill name..."
          />
          <select id="rarity-filter" class="bb-defdown-filter-select">
            <option value="">All Rarities</option>
            {rarities.map(r => <option value={r}>{r}</option>)}
          </select>
          <select id="element-filter" class="bb-defdown-filter-select">
            <option value="">All Elements</option>
            {elements.map(el => <option value={el}>{el}</option>)}
          </select>
          <select id="tier-filter" class="bb-defdown-filter-select">
            <option value="">All Tiers</option>
            <option value="S">S Tier (-23% -320)</option>
            <option value="A">A Tier (-21% -220)</option>
            <option value="B">B Tier (-18% -210)</option>
            <option value="C">C Tier (Other)</option>
          </select>
          <select id="target-filter" class="bb-defdown-filter-select">
            <option value="">All Targets</option>
            <option value="single">Single (Cat. B)</option>
            <option value="multi">Multi (Cat. C)</option>
          </select>
          <button type="button" id="clear-filters" class="bb-defdown-clear-btn">Clear All</button>
        </div>
      </div>

      <!-- Results Count -->
      <div class="bb-defdown-results-count" id="results-count">
        Showing <span>{totalSkills}</span> skills
      </div>

      <!-- S Tier Section -->
      {tierS.length > 0 && (
        <div class="bb-defdown-tier-section" data-tier="S">
          <div class="bb-defdown-tier-header">
            <span class="bb-defdown-tier-badge">S</span>
            <div class="bb-defdown-tier-info">
              <h2 class="bb-defdown-tier-title">S Tier - Best Magic DEF Down</h2>
              <p class="bb-defdown-tier-desc">-23% and -320 flat reduction (Lv90)</p>
            </div>
            <span class="bb-defdown-tier-count">{tierS.length} skills</span>
          </div>
          <div class="bb-defdown-grid">
            {tierS.map(skill => (
              <div
                class="bb-defdown-card"
                data-name={skill.characterName.toLowerCase()}
                data-skill={skill.skillName.toLowerCase()}
                data-element={skill.element?.toLowerCase()}
                data-rarity={skill.rarity?.toLowerCase()}
                data-tier="s"
                data-target={skill.targetType}
              >
                <div class="bb-defdown-card-header">
                  <div class="bb-defdown-card-avatar">
                    <PaladinImage characterId={skill.characterId} alt={skill.characterName} width={60} height={60} />
                  </div>
                  <div class="bb-defdown-card-info">
                    <h3 class="bb-defdown-card-name">{skill.characterName}</h3>
                    <div class="bb-defdown-card-meta">
                      {skill.rarity && (
                        <span class="bb-defdown-meta-item bb-defdown-rarity">
                          <RarityImage rarity={skill.rarity} width={80} height={40} class="bb-defdown-rarity-img" />
                        </span>
                      )}
                      {skill.element && (
                        <span class="bb-defdown-meta-item">
                          <ElementImage element={skill.element} width={16} height={16} />
                          {skill.element}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
                <div class="bb-defdown-card-body">
                  <div class="bb-defdown-skill-row">
                    <div class="bb-defdown-skill-icon">
                      <SkillIcon skillId={skill.skillIcon} alt={skill.skillName} width={36} height={36} />
                    </div>
                    <div class="bb-defdown-skill-info">
                      <div class="bb-defdown-skill-name">{skill.skillName}</div>
                      <div class="bb-defdown-skill-slot">Skill {skill.skillSlot}</div>
                    </div>
                  </div>
                  <div class="bb-defdown-values">
                    <span class="bb-defdown-lv-badge">Lv90</span>
                    <div class="bb-defdown-value-main">
                      {skill.percent > 0 ? <span class="bb-defdown-value-percent">-{skill.percent}%</span> : null}
                      {skill.flat > 0 ? <span class="bb-defdown-value-flat">-{skill.flat}</span> : null}
                    </div>
                    <div class="bb-defdown-value-duration">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                      </svg>
                      {skill.duration}s
                    </div>
                  </div>
                  <div class="bb-defdown-target">
                    Target: <span>{skill.target}</span>
                    <span class={`bb-defdown-target-badge ${skill.targetType}`}>
                      {skill.targetType === 'single' ? 'Single (B)' : 'Multi (C)'}
                    </span>
                  </div>
                  {skill.description && <div class="bb-defdown-description">{skill.description}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- A Tier Section -->
      {tierA.length > 0 && (
        <div class="bb-defdown-tier-section" data-tier="A">
          <div class="bb-defdown-tier-header">
            <span class="bb-defdown-tier-badge">A</span>
            <div class="bb-defdown-tier-info">
              <h2 class="bb-defdown-tier-title">A Tier - Strong Magic DEF Down</h2>
              <p class="bb-defdown-tier-desc">-21% and -220 flat reduction (Lv90)</p>
            </div>
            <span class="bb-defdown-tier-count">{tierA.length} skills</span>
          </div>
          <div class="bb-defdown-grid">
            {tierA.map(skill => (
              <div
                class="bb-defdown-card"
                data-name={skill.characterName.toLowerCase()}
                data-skill={skill.skillName.toLowerCase()}
                data-element={skill.element?.toLowerCase()}
                data-rarity={skill.rarity?.toLowerCase()}
                data-tier="a"
                data-target={skill.targetType}
              >
                <div class="bb-defdown-card-header">
                  <div class="bb-defdown-card-avatar">
                    <PaladinImage characterId={skill.characterId} alt={skill.characterName} width={60} height={60} />
                  </div>
                  <div class="bb-defdown-card-info">
                    <h3 class="bb-defdown-card-name">{skill.characterName}</h3>
                    <div class="bb-defdown-card-meta">
                      {skill.rarity && (
                        <span class="bb-defdown-meta-item bb-defdown-rarity">
                          <RarityImage rarity={skill.rarity} width={80} height={40} class="bb-defdown-rarity-img" />
                        </span>
                      )}
                      {skill.element && (
                        <span class="bb-defdown-meta-item">
                          <ElementImage element={skill.element} width={16} height={16} />
                          {skill.element}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
                <div class="bb-defdown-card-body">
                  <div class="bb-defdown-skill-row">
                    <div class="bb-defdown-skill-icon">
                      <SkillIcon skillId={skill.skillIcon} alt={skill.skillName} width={36} height={36} />
                    </div>
                    <div class="bb-defdown-skill-info">
                      <div class="bb-defdown-skill-name">{skill.skillName}</div>
                      <div class="bb-defdown-skill-slot">Skill {skill.skillSlot}</div>
                    </div>
                  </div>
                  <div class="bb-defdown-values">
                    <span class="bb-defdown-lv-badge">Lv90</span>
                    <div class="bb-defdown-value-main">
                      {skill.percent > 0 ? <span class="bb-defdown-value-percent">-{skill.percent}%</span> : null}
                      {skill.flat > 0 ? <span class="bb-defdown-value-flat">-{skill.flat}</span> : null}
                    </div>
                    <div class="bb-defdown-value-duration">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                      </svg>
                      {skill.duration}s
                    </div>
                  </div>
                  <div class="bb-defdown-target">
                    Target: <span>{skill.target}</span>
                    <span class={`bb-defdown-target-badge ${skill.targetType}`}>
                      {skill.targetType === 'single' ? 'Single (B)' : 'Multi (C)'}
                    </span>
                  </div>
                  {skill.description && <div class="bb-defdown-description">{skill.description}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- B Tier Section -->
      {tierB.length > 0 && (
        <div class="bb-defdown-tier-section" data-tier="B">
          <div class="bb-defdown-tier-header">
            <span class="bb-defdown-tier-badge">B</span>
            <div class="bb-defdown-tier-info">
              <h2 class="bb-defdown-tier-title">B Tier - Moderate Magic DEF Down</h2>
              <p class="bb-defdown-tier-desc">-18% and -210 flat reduction (Lv90)</p>
            </div>
            <span class="bb-defdown-tier-count">{tierB.length} skills</span>
          </div>
          <div class="bb-defdown-grid">
            {tierB.map(skill => (
              <div
                class="bb-defdown-card"
                data-name={skill.characterName.toLowerCase()}
                data-skill={skill.skillName.toLowerCase()}
                data-element={skill.element?.toLowerCase()}
                data-rarity={skill.rarity?.toLowerCase()}
                data-tier="b"
                data-target={skill.targetType}
              >
                <div class="bb-defdown-card-header">
                  <div class="bb-defdown-card-avatar">
                    <PaladinImage characterId={skill.characterId} alt={skill.characterName} width={60} height={60} />
                  </div>
                  <div class="bb-defdown-card-info">
                    <h3 class="bb-defdown-card-name">{skill.characterName}</h3>
                    <div class="bb-defdown-card-meta">
                      {skill.rarity && (
                        <span class="bb-defdown-meta-item bb-defdown-rarity">
                          <RarityImage rarity={skill.rarity} width={80} height={40} class="bb-defdown-rarity-img" />
                        </span>
                      )}
                      {skill.element && (
                        <span class="bb-defdown-meta-item">
                          <ElementImage element={skill.element} width={16} height={16} />
                          {skill.element}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
                <div class="bb-defdown-card-body">
                  <div class="bb-defdown-skill-row">
                    <div class="bb-defdown-skill-icon">
                      <SkillIcon skillId={skill.skillIcon} alt={skill.skillName} width={36} height={36} />
                    </div>
                    <div class="bb-defdown-skill-info">
                      <div class="bb-defdown-skill-name">{skill.skillName}</div>
                      <div class="bb-defdown-skill-slot">Skill {skill.skillSlot}</div>
                    </div>
                  </div>
                  <div class="bb-defdown-values">
                    <span class="bb-defdown-lv-badge">Lv90</span>
                    <div class="bb-defdown-value-main">
                      {skill.percent > 0 ? <span class="bb-defdown-value-percent">-{skill.percent}%</span> : null}
                      {skill.flat > 0 ? <span class="bb-defdown-value-flat">-{skill.flat}</span> : null}
                    </div>
                    <div class="bb-defdown-value-duration">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                      </svg>
                      {skill.duration}s
                    </div>
                  </div>
                  <div class="bb-defdown-target">
                    Target: <span>{skill.target}</span>
                    <span class={`bb-defdown-target-badge ${skill.targetType}`}>
                      {skill.targetType === 'single' ? 'Single (B)' : 'Multi (C)'}
                    </span>
                  </div>
                  {skill.description && <div class="bb-defdown-description">{skill.description}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- C Tier Section -->
      {tierC.length > 0 && (
        <div class="bb-defdown-tier-section" data-tier="C">
          <div class="bb-defdown-tier-header">
            <span class="bb-defdown-tier-badge bb-defdown-tier-badge-c">C</span>
            <div class="bb-defdown-tier-info">
              <h2 class="bb-defdown-tier-title">C Tier - Lower Magic DEF Down</h2>
              <p class="bb-defdown-tier-desc">Lower reduction values (Lv90)</p>
            </div>
            <span class="bb-defdown-tier-count">{tierC.length} skills</span>
          </div>
          <div class="bb-defdown-grid">
            {tierC.map(skill => (
              <div
                class="bb-defdown-card"
                data-name={skill.characterName.toLowerCase()}
                data-skill={skill.skillName.toLowerCase()}
                data-element={skill.element?.toLowerCase()}
                data-rarity={skill.rarity?.toLowerCase()}
                data-tier="c"
                data-target={skill.targetType}
              >
                <div class="bb-defdown-card-header">
                  <div class="bb-defdown-card-avatar">
                    <PaladinImage characterId={skill.characterId} alt={skill.characterName} width={60} height={60} />
                  </div>
                  <div class="bb-defdown-card-info">
                    <h3 class="bb-defdown-card-name">{skill.characterName}</h3>
                    <div class="bb-defdown-card-meta">
                      {skill.rarity && (
                        <span class="bb-defdown-meta-item bb-defdown-rarity">
                          <RarityImage rarity={skill.rarity} width={80} height={40} class="bb-defdown-rarity-img" />
                        </span>
                      )}
                      {skill.element && (
                        <span class="bb-defdown-meta-item">
                          <ElementImage element={skill.element} width={16} height={16} />
                          {skill.element}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
                <div class="bb-defdown-card-body">
                  <div class="bb-defdown-skill-row">
                    <div class="bb-defdown-skill-icon">
                      <SkillIcon skillId={skill.skillIcon} alt={skill.skillName} width={36} height={36} />
                    </div>
                    <div class="bb-defdown-skill-info">
                      <div class="bb-defdown-skill-name">{skill.skillName}</div>
                      <div class="bb-defdown-skill-slot">Skill {skill.skillSlot}</div>
                    </div>
                  </div>
                  <div class="bb-defdown-values">
                    <span class="bb-defdown-lv-badge">Lv90</span>
                    <div class="bb-defdown-value-main">
                      {skill.percent > 0 ? <span class="bb-defdown-value-percent">-{skill.percent}%</span> : null}
                      {skill.flat > 0 ? <span class="bb-defdown-value-flat">-{skill.flat}</span> : null}
                    </div>
                    <div class="bb-defdown-value-duration">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                      </svg>
                      {skill.duration}s
                    </div>
                  </div>
                  <div class="bb-defdown-target">
                    Target: <span>{skill.target}</span>
                    <span class={`bb-defdown-target-badge ${skill.targetType}`}>
                      {skill.targetType === 'single' ? 'Single (B)' : 'Multi (C)'}
                    </span>
                  </div>
                  {skill.description && <div class="bb-defdown-description">{skill.description}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- No Results -->
      <div class="bb-defdown-no-results" id="no-results">
        <h3>No skills found</h3>
        <p>Try adjusting your search or filter criteria.</p>
      </div>
    </div>

    <!-- ULTIMATES SECTION -->
    <div class="bb-defdown-tab-content" id="ultimates-content">
      <div class="bb-defdown-info-box" style="margin-bottom: 1.5rem;">
        <h3 class="bb-defdown-info-title">Ultimate Magic Defense Down</h3>
        <p class="bb-defdown-info-text">
          Ultimate skills have Defense Down that scales with Ultimate Level. Values shown are at max level (LV5).
        </p>
        <p class="bb-defdown-info-text" style="margin-top: 0.75rem;">
          <strong>Category A:</strong> All Ultimate debuffs share Category A (regardless of single/multi-target).
          Multiple ultimate debuffs won't stack, but <strong>Ultimate + Skill debuffs CAN stack</strong> since they're different categories.
        </p>
      </div>

      {sortedUltimates.length > 0 ? (
        <div class="bb-defdown-grid">
          {sortedUltimates.map(ult => (
            <div
              class="bb-defdown-card bb-defdown-card-ultimate"
              data-name={ult.characterName.toLowerCase()}
            >
              <div class="bb-defdown-card-header">
                <div class="bb-defdown-card-avatar">
                  <PaladinImage characterId={ult.characterId} alt={ult.characterName} width={60} height={60} />
                </div>
                <div class="bb-defdown-card-info">
                  <h3 class="bb-defdown-card-name">{ult.characterName}</h3>
                  <div class="bb-defdown-card-meta">
                    {ult.rarity && (
                      <span class="bb-defdown-meta-item bb-defdown-rarity">
                        <RarityImage rarity={ult.rarity} width={80} height={40} class="bb-defdown-rarity-img" />
                      </span>
                    )}
                    {ult.element && (
                      <span class="bb-defdown-meta-item">
                        <ElementImage element={ult.element} width={16} height={16} />
                        {ult.element}
                      </span>
                    )}
                  </div>
                </div>
              </div>
              <div class="bb-defdown-card-body">
                <div class="bb-defdown-skill-row">
                  <div class="bb-defdown-skill-icon">
                    <SkillIcon skillId={ult.skillIcon} alt={ult.skillName} width={36} height={36} />
                  </div>
                  <div class="bb-defdown-skill-info">
                    <div class="bb-defdown-skill-name">{ult.skillName}</div>
                    <div class="bb-defdown-skill-slot">Ultimate LV{ult.level}</div>
                  </div>
                </div>
                <div class="bb-defdown-values">
                  <span class="bb-defdown-lv-badge">LV5</span>
                  <div class="bb-defdown-value-main">
                    {ult.percent && ult.percent > 0 ? <span class="bb-defdown-value-percent">-{ult.percent}%</span> : <span class="bb-defdown-value-percent">DOWN</span>}
                    {ult.flat && ult.flat > 0 ? <span class="bb-defdown-value-flat">-{ult.flat}</span> : null}
                  </div>
                  {ult.duration && (
                    <div class="bb-defdown-value-duration">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                      </svg>
                      {ult.duration}s
                    </div>
                  )}
                </div>
                {ult.description && <div class="bb-defdown-description">{ult.description}</div>}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="bb-defdown-no-results visible">
          <h3>No ultimates found</h3>
          <p>No characters with Magic Defense Down on their ultimate.</p>
        </div>
      )}
    </div>
  </div>
</DefenseDownLayout>

<script>
  function initPage() {
    // Tab switching
    const tabs = document.querySelectorAll('.bb-defdown-tab');
    const contents = document.querySelectorAll('.bb-defdown-tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const tabId = tab.getAttribute('data-tab');

        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));

        tab.classList.add('active');
        document.getElementById(`${tabId}-content`)?.classList.add('active');
      });
    });

    // Filters (only for skills tab)
    const searchInput = document.getElementById('defdown-search') as HTMLInputElement;
    const rarityFilter = document.getElementById('rarity-filter') as HTMLSelectElement;
    const elementFilter = document.getElementById('element-filter') as HTMLSelectElement;
    const tierFilter = document.getElementById('tier-filter') as HTMLSelectElement;
    const targetFilter = document.getElementById('target-filter') as HTMLSelectElement;
    const clearBtn = document.getElementById('clear-filters');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');

    const cards = document.querySelectorAll('#skills-content .bb-defdown-card');
    const tierSections = document.querySelectorAll('#skills-content .bb-defdown-tier-section');

    function filterCards() {
      const search = searchInput?.value.toLowerCase() || '';
      const rarity = rarityFilter?.value.toLowerCase() || '';
      const element = elementFilter?.value.toLowerCase() || '';
      const tier = tierFilter?.value.toLowerCase() || '';
      const target = targetFilter?.value.toLowerCase() || '';

      let visibleCount = 0;

      cards.forEach(card => {
        const cardEl = card as HTMLElement;
        const matchName = !search ||
          cardEl.dataset.name?.includes(search) ||
          cardEl.dataset.skill?.includes(search);
        const matchRarity = !rarity || cardEl.dataset.rarity === rarity;
        const matchElement = !element || cardEl.dataset.element === element;
        const matchTier = !tier || cardEl.dataset.tier === tier;
        const matchTarget = !target || cardEl.dataset.target === target;

        const isVisible = matchName && matchRarity && matchElement && matchTier && matchTarget;
        cardEl.classList.toggle('hidden', !isVisible);
        if (isVisible) visibleCount++;
      });

      // Hide empty tier sections
      tierSections.forEach(section => {
        const sectionEl = section as HTMLElement;
        const visibleCards = sectionEl.querySelectorAll('.bb-defdown-card:not(.hidden)');
        sectionEl.style.display = visibleCards.length > 0 ? 'block' : 'none';
      });

      // Show/hide no results message
      if (noResults) {
        noResults.classList.toggle('visible', visibleCount === 0);
      }

      // Update results count
      if (resultsCount) {
        const span = resultsCount.querySelector('span');
        if (span) span.textContent = visibleCount.toString();
      }
    }

    function clearFilters() {
      if (searchInput) searchInput.value = '';
      if (rarityFilter) rarityFilter.value = '';
      if (elementFilter) elementFilter.value = '';
      if (tierFilter) tierFilter.value = '';
      if (targetFilter) targetFilter.value = '';
      filterCards();
    }

    searchInput?.addEventListener('input', filterCards);
    rarityFilter?.addEventListener('change', filterCards);
    elementFilter?.addEventListener('change', filterCards);
    tierFilter?.addEventListener('change', filterCards);
    targetFilter?.addEventListener('change', filterCards);
    clearBtn?.addEventListener('click', clearFilters);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPage);
  } else {
    initPage();
  }
</script>
